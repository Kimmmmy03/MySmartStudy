# Gemini AI API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase service account (path to the JSON file)
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Firebase Storage bucket name (e.g. your-project-id.appspot.com)
# If left empty, AI-generated images fall back to local disk (uploads/ai-images/)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# JWT secret for token signing
SECRET_KEY=change-me-to-a-strong-random-secret

# ── RAG cross-encoder reranker (optional quality enhancement) ──
# The default model (BAAI/bge-reranker-v2-m3) needs ~2.5GB RAM. On instances
# with less than RAG_RERANK_MIN_AVAIL_MB free memory the reranker is auto-skipped
# (RAG still works via embedding-similarity ordering) so the worker is never
# OOM-killed. To keep reranking ON in a memory-constrained deploy, point
# RAG_RERANKER_MODEL at a small model, e.g. cross-encoder/ms-marco-MiniLM-L-6-v2.
# RAG_RERANK_ENABLED=1
# RAG_RERANK_MIN_AVAIL_MB=3000
# RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# SMTP settings for email (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
