<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="gagSimple" name="GAG (Simple)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Why AI Suggestions Look Polished, Not Like a Chat Reply" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="300" y="24" width="1400" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Instead of writing a loose paragraph, the AI fills in a tidy form — so the app can turn it into charts, links and lists." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="250" y="70" width="1500" height="28" as="geometry" />
        </mxCell>

        <!-- THE TWO WAYS -->
        <mxCell id="way_a" value="❌  A plain chat reply" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="860" height="280" as="geometry" />
        </mxCell>
        <mxCell id="chat" value="&quot;You should probably study databases first,&#xa;maybe spend an hour on it, and normalisation&#xa;is important too, also don't forget the quiz&#xa;is coming up soon so revise that as well...&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=middle;fontSize=13;fontColor=#1F3A68;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="120" y="185" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="chat_note" value="The app cannot turn loose text into buttons,&#xa;links, time slots or charts — it is just words." style="text;html=1;align=left;whiteSpace=wrap;fontSize=13;fontStyle=2;fontColor=#3D4A5C;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="120" y="320" width="780" height="60" as="geometry" />
        </mxCell>

        <mxCell id="way_b" value="✅  A filled-in form  (this is what MySmartStudy does)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F0F8;strokeColor=#6B46C1;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1000" y="130" width="920" height="280" as="geometry" />
        </mxCell>
        <mxCell id="form" value="Topic:        Normalisation&#xa;Priority:     High&#xa;Time slot:    9:00 - 10:00 am&#xa;Difficulty:   ★★★★☆&#xa;Resource:     [ Lecture 3 - Normal Forms ]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=middle;fontSize=13;fontColor=#4C2F87;spacingLeft=14;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="1040" y="185" width="840" height="120" as="geometry" />
        </mxCell>
        <mxCell id="form_note" value="Every field has a fixed place — so the app can show it as a&#xa;timetable, a clickable link, a star rating or a chart." style="text;html=1;align=left;whiteSpace=wrap;fontSize=13;fontStyle=2;fontColor=#4C2F87;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="1040" y="320" width="840" height="60" as="geometry" />
        </mxCell>

        <!-- WHERE IT IS USED -->
        <mxCell id="uses" value="The AI fills a different form for each of these four features" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="1840" height="320" as="geometry" />
        </mxCell>
        <mxCell id="u1" value="📅  Daily Study Plan&#xa;A list of topics, each with a time&#xa;slot, priority and a link to the&#xa;right course material." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="130" y="535" width="410" height="150" as="geometry" />
        </mxCell>
        <mxCell id="u2" value="📊  Grading Report&#xa;A score for each rubric criterion,&#xa;a clear reason, and tips for the&#xa;student to improve." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="580" y="535" width="410" height="150" as="geometry" />
        </mxCell>
        <mxCell id="u3" value="🧠  Mind-Map Suggestions&#xa;New nodes to add, each linked to&#xa;the correct existing node and to a&#xa;source in the course materials." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1030" y="535" width="410" height="150" as="geometry" />
        </mxCell>
        <mxCell id="u4" value="🔍  Plagiarism Report&#xa;Groups of students whose work&#xa;is too alike, with a similarity&#xa;score and a short explanation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1480" y="535" width="400" height="150" as="geometry" />
        </mxCell>
        <mxCell id="uses_note" value="💡  The AI engine — filling these forms can be done by two interchangeable engines: a custom-built one, or one made from a popular ready-made AI toolkit (LangChain). Both produce the very same tidy form; an admin can switch between them at any time." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="130" y="705" width="1750" height="64" as="geometry" />
        </mxCell>

        <!-- ARROW -->
        <mxCell id="arrow" value="the tidy form becomes..." style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2.5;fontSize=12;fontColor=#4C2F87;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="way_b" target="uses"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1460" y="445" /><mxPoint x="1000" y="445" /></Array></mxGeometry></mxCell>

        <mxCell id="footer" value="Why it matters:  a tidy form lets MySmartStudy show AI results as real charts, links and lists — not just a wall of text." style="text;html=1;align=center;whiteSpace=wrap;fontSize=14;fontStyle=2;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="250" y="820" width="1500" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
