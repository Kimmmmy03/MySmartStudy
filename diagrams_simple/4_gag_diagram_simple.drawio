<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="gagSimple" name="GAG (Simple)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="When the AI Doesn't Just Write — It Fills in a Form" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1400" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Instead of one block of free text, the AI returns a tidy result the app can show as charts, lists and links." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="200" y="64" width="1600" height="30" as="geometry" />
        </mxCell>

        <!-- =========== COMPARISON =========== -->
        <mxCell id="cmp_left_title" value="Plain AI answer (free text)" style="text;html=1;align=center;fontStyle=1;fontSize=15;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="920" height="28" as="geometry" />
        </mxCell>
        <mxCell id="cmp_left" value="&quot;This essay shows a good understanding of the topic.&#10;The student covered the main points but missed&#10;a few details on normalisation. Overall I would&#10;give it around 72%.&quot;&#10;&#10;Looks fine — but the app can't easily display it&#10;as a grade bar, a criterion breakdown, or a link&#10;back to the lecture slide that explains the&#10;missing point." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6478;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontColor=#3D4A5C;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="840" height="240" as="geometry" />
        </mxCell>

        <mxCell id="cmp_right_title" value="Structured AI answer (a filled-in form)" style="text;html=1;align=center;fontStyle=1;fontSize=15;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1000" y="110" width="920" height="28" as="geometry" />
        </mxCell>
        <mxCell id="cmp_right" value="Suggested grade — 72 / 100&#10;Confidence — 0.85&#10;&#10;Criterion scores&#10;  Content quality .......... 25 / 30&#10;  Structure ................. 18 / 20&#10;  Use of sources .......... 16 / 20&#10;  Normalisation depth ... 13 / 30&#10;&#10;Justification — clear writing, good intro,&#10;weak discussion of 3NF.&#10;&#10;Suggested improvements&#10;  • Re-read &quot;Normalisation&quot; (Lecture 5)&#10;  • Add an example of a 3NF table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontColor=#4C2F87;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="1040" y="150" width="840" height="240" as="geometry" />
        </mxCell>

        <!-- arrow between the two -->
        <mxCell id="cmp_arrow" value="same source —&#10;better shape →" style="text;html=1;align=center;fontStyle=2;fontSize=14;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="930" y="240" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- =========== HOW IT WORKS =========== -->
        <mxCell id="how" value="How the AI does it" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=15;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1920" height="450" as="geometry" />
        </mxCell>

        <mxCell id="h_inputs" value="① Gather everything needed&#10;&#10;• The student's submission&#10;• The rubric (what to mark)&#10;• Similar past work from the&#10;   AI's library (RAG)&#10;• Class average / median&#10;• How well the student usually&#10;   does in this topic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1F3A68;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="380" height="240" as="geometry" />
        </mxCell>

        <mxCell id="h_form" value="② Hand the AI a blank form&#10;&#10;The app tells the AI:&#10;&quot;Fill in this exact form.&#10;Use the rubric criteria.&#10;Cite a real lecture file&#10;for every suggestion.&quot;&#10;&#10;The form is the template you&#10;saw above on the right." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="510" y="490" width="380" height="240" as="geometry" />
        </mxCell>

        <mxCell id="h_check" value="③ The app checks the form&#10;&#10;If a section was left empty&#10;(e.g. no source link), the app&#10;auto-fills it from the matching&#10;passages it already found.&#10;&#10;If a referenced topic doesn't&#10;exist in the mind map, that&#10;item is dropped." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="940" y="490" width="380" height="240" as="geometry" />
        </mxCell>

        <mxCell id="h_show" value="④ Show it in the app&#10;&#10;Because the AI returned&#10;structured data, the app can&#10;turn it into:&#10;  • a grade number&#10;  • a criterion bar chart&#10;  • clickable source links&#10;  • a list of improvements&#10;  • a graph for plagiarism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="1370" y="490" width="380" height="240" as="geometry" />
        </mxCell>

        <!-- chain arrows (between adjacent boxes only — never crossing) -->
        <mxCell id="he1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="h_inputs" target="h_form"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="he2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#5A6478" edge="1" parent="1" source="h_form" target="h_check"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="he3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="h_check" target="h_show"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- =========== WHERE USED =========== -->
        <mxCell id="uses_title" value="Where MySmartStudy uses this trick" style="text;html=1;align=left;fontStyle=1;fontSize=15;fontColor=#3D4A5C;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="900" width="1920" height="28" as="geometry" />
        </mxCell>

        <mxCell id="u_plan" value="Daily Study Plan&#10;&#10;Form contains — course name,&#10;topic, why study it today,&#10;suggested time slot,&#10;estimated minutes,&#10;difficulty 1-5,&#10;linked lecture file." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="80" y="935" width="430" height="170" as="geometry" />
        </mxCell>
        <mxCell id="u_grade" value="AI Grade Suggestion (Lecturer)&#10;&#10;Form contains — overall grade,&#10;each criterion score,&#10;justification paragraph,&#10;comparison to class average,&#10;improvement tips with links." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=left;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#3F2A6B;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="540" y="935" width="430" height="170" as="geometry" />
        </mxCell>
        <mxCell id="u_buddy" value="Mind Map Suggestions&#10;&#10;Form contains — new node label,&#10;short description,&#10;which existing node to attach to,&#10;source citation,&#10;connections to other nodes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1000" y="935" width="430" height="170" as="geometry" />
        </mxCell>
        <mxCell id="u_plag" value="Plagiarism Network&#10;&#10;Form contains — cluster groups,&#10;maximum similarity score,&#10;students involved,&#10;explanation of what was shared,&#10;overall summary." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=left;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#3F2A6B;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1460" y="935" width="430" height="170" as="geometry" />
        </mxCell>

        <!-- Takeaway -->
        <mxCell id="takeaway" value="Why this is useful&#10;&#10;Free text is hard for an app to display nicely.  A filled-in form is easy — every field becomes a number, a chart bar, a clickable link, or a row in a table.&#10;That's why the AI suggestions you see in MySmartStudy look polished, not like a chat reply." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="1130" width="1920" height="100" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
