        <mxCell id="ce7" value="used in" edge="1" parent="1" source="c_sql" target="c_db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=1;endArrow=open;fontSize=11;strokeWidth=2;strokeColor=#4A5568;fontColor=#3D4A5C">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="860" y="480" /><mxPoint x="190" y="480" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="useA_note" value="What it's for&#xa;&#xa;When a student building a mind map types&#xa;&quot;ER Model&quot;, the AI suggests related ideas it&#xa;already knows from the course — Primary Key,&#xa;Normalisation, EER Model — and explains how&#xa;they connect.&#xa;&#xa;Because the AI keeps a map (not just plain text),&#xa;it recommends the RIGHT next idea, not&#xa;random ones." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1340" y="170" width="620" height="390" as="geometry" />
        </mxCell>

        <!-- USE 2 — PLAGIARISM -->
        <mxCell id="useB" value="Use 2 — Catching copied submissions&#xa;The AI compares every student's submission and draws a &quot;similarity map.&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=15;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1920" height="500" as="geometry" />
        </mxCell>

        <mxCell id="sb1" value="📥  Collect&#xa;all submissions&#xa;for one assignment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="90" y="700" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sb2" value="📏  Measure how alike&#xa;every pair of submissions is&#xa;(0% = different,  100% = identical)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="490" y="700" width="430" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sb3" value="🔗  Group submissions that&#xa;are very alike into &quot;clusters&quot;&#xa;(flagged when 70%+ similar)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1000" y="700" width="430" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sb4" value="📋  Show the lecturer&#xa;a clear report of which&#xa;students may have copied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1510" y="700" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sbe1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="sb1" target="sb2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sbe2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="sb2" target="sb3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sbe3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="sb3" target="sb4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="useB_note" value="💡  The AI engine — both the course mind-map and the copy-checking can run on two interchangeable engines: a custom-built one, or one made from popular ready-made AI toolkits (LangChain and CrewAI). The result is the same; an admin can switch between them at any time." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="90" y="870" width="1800" height="70" as="geometry" />
        </mxCell>
        <mxCell id="footer" value="Why it matters:  the &quot;maps&quot; let the AI give smarter study suggestions and help lecturers spot copying fairly." style="text;html=1;align=center;whiteSpace=wrap;fontSize=14;fontStyle=2;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="90" y="970" width="1800" height="30" as="geometry" />
        </mxCell>
      </root>
