<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="ragSimple" name="RAG (Simple)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="How the AI Reads Your Course Materials" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="1200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Think of it like a librarian who reads every book in the course, then answers questions using the real pages." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="200" y="64" width="1600" height="30" as="geometry" />
        </mxCell>

        <!-- ============ PART A: AI READS MATERIALS ============ -->
        <mxCell id="partA" value="Part 1 — Once, in the background:  the AI reads and remembers everything" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=16;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="1920" height="320" as="geometry" />
        </mxCell>

        <mxCell id="A_src" value="📚 Course materials&#10;&#10;Lecture PDFs&#10;Announcements&#10;Mind maps&#10;Quiz questions&#10;Discussion posts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1F3A68;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="270" height="200" as="geometry" />
        </mxCell>

        <mxCell id="A_read" value="Step 1 — Read&#10;&#10;The AI opens each PDF&#10;and extracts the text&#10;(even scanned pages —&#10;like a smart OCR)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="430" y="180" width="270" height="200" as="geometry" />
        </mxCell>

        <mxCell id="A_chunk" value="Step 2 — Split into parts&#10;&#10;Big documents are split&#10;into short passages&#10;(about a paragraph each)&#10;so they are easier to&#10;match against questions." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="780" y="180" width="270" height="200" as="geometry" />
        </mxCell>

        <mxCell id="A_embed" value="Step 3 — Make meaning fingerprints&#10;&#10;Each passage gets a&#10;fingerprint that captures&#10;what it MEANS.&#10;&#10;Two passages on the same&#10;topic get similar fingerprints&#10;even if the words differ." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1130" y="180" width="290" height="200" as="geometry" />
        </mxCell>

        <mxCell id="A_store" value="AI Memory&#10;&#10;Passages + fingerprints&#10;are filed away in a&#10;searchable library." style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingLeft=18;spacingTop=14" vertex="1" parent="1">
          <mxGeometry x="1500" y="180" width="290" height="200" as="geometry" />
        </mxCell>

        <!-- Part A arrows (straight, adjacent) -->
        <mxCell id="ae1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="A_src" target="A_read"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="A_read" target="A_chunk"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="A_chunk" target="A_embed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="A_embed" target="A_store"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="A_note" value="Why &quot;fingerprints&quot;?  Plain word-matching misses ideas.&#10;&quot;Heart attack&quot; and &quot;cardiac arrest&quot; mean the same thing — the fingerprint catches that;  a simple text search won't." style="text;html=1;align=center;whiteSpace=wrap;fontSize=13;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="100" y="400" width="1820" height="34" as="geometry" />
        </mxCell>

        <!-- ============ PART B: STUDENT ASKS QUESTION ============ -->
        <mxCell id="partB" value="Part 2 — Every time a student asks a question:" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=16;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1920" height="540" as="geometry" />
        </mxCell>

        <mxCell id="B_q" value="Student question&#10;&#10;&quot;What is the difference&#10;between an ER model and&#10;an EER model?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1F3A68;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="270" height="180" as="geometry" />
        </mxCell>

        <mxCell id="B_break" value="Step 1 — Break it down&#10;&#10;If the question has&#10;multiple parts the AI&#10;splits them so it&#10;can search each one.&#10;&#10;(Skipped for simple Qs.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="430" y="540" width="270" height="180" as="geometry" />
        </mxCell>

        <mxCell id="B_fp" value="Step 2 — Make a&#10;fingerprint of the question&#10;&#10;Same method as Part 1." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="780" y="540" width="270" height="180" as="geometry" />
        </mxCell>

        <mxCell id="B_find" value="Step 3 — Find matches&#10;&#10;Compare the question's&#10;fingerprint to every&#10;passage in the library&#10;and pick the closest&#10;ones." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1130" y="540" width="290" height="180" as="geometry" />
        </mxCell>

        <mxCell id="B_rerank" value="Step 4 — Re-rank&#10;&#10;A second pass reads&#10;the top matches more&#10;carefully and re-orders&#10;them so the best one&#10;comes first." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1500" y="540" width="290" height="180" as="geometry" />
        </mxCell>

        <!-- Part B chain arrows -->
        <mxCell id="be1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="B_q" target="B_break"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="be2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="B_break" target="B_fp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="be3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="B_fp" target="B_find"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="be4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="B_find" target="B_rerank"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Step 3 → AI Memory (the back-reference up to Part 1's store) — routed AROUND boxes via right margin -->
        <mxCell id="be_library" value="search the library" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=1;endArrow=classic;dashed=1;strokeWidth=2;strokeColor=#4A6E8C;fontSize=12;fontColor=#2E4A66" edge="1" parent="1" source="B_find" target="A_store">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1450" y="630" />
              <mxPoint x="1450" y="430" />
              <mxPoint x="1645" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Compose row -->
        <mxCell id="B_compose" value="Step 5 — Write the answer&#10;&#10;The AI is given&#10;  • the student's question&#10;  • the top matching passages&#10;&#10;It writes an answer using&#10;those real passages — not&#10;a guess." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="430" y="770" width="370" height="200" as="geometry" />
        </mxCell>

        <mxCell id="B_out" value="Final answer + sources&#10;&#10;Student sees the answer with&#10;a list of which lecture files&#10;or pages it came from — so&#10;they can verify it.&#10;&#10;[Source 1]  Lecture 4 — ER models&#10;[Source 2]  Lecture 5 — EER models" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#1F3A68;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="850" y="770" width="430" height="200" as="geometry" />
        </mxCell>

        <mxCell id="B_why" value="Why this matters&#10;&#10;Without this process, the AI&#10;might invent facts (&quot;hallucinate&quot;).&#10;With it, every answer is&#10;grounded in your actual course&#10;materials — and you can check&#10;the source." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="1330" y="770" width="460" height="200" as="geometry" />
        </mxCell>

        <!-- Re-rank → Compose:  goes down then left, around no boxes -->
        <mxCell id="be5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="B_rerank" target="B_compose">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1645" y="745" />
              <mxPoint x="615" y="745" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="be6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeWidth=2;strokeColor=#2C5282" edge="1" parent="1" source="B_compose" target="B_out"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Takeaway -->
        <mxCell id="takeaway" value="In one sentence — &quot;Don't trust an AI that answers from memory; trust an AI that shows you the page it read.&quot;  That's what this whole process is for." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECEFF5;strokeColor=#4A6E8C;fontSize=14;fontColor=#2E4A66;align=center;spacingTop=14" vertex="1" parent="1">
          <mxGeometry x="40" y="1050" width="1920" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
