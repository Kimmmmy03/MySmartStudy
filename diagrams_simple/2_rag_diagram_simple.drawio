<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="ragSimple" name="RAG (Simple)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="How the AI Reads Course Materials" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="400" y="24" width="1200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Like a librarian who reads every book first, then answers using the real pages — so it never makes things up." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="1400" height="28" as="geometry" />
        </mxCell>

        <!-- STEP A — GETTING READY -->
        <mxCell id="a" value="Step A — Getting ready  (done once, in the background)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=18;spacingTop=10;fontSize=16;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="1840" height="280" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="📚  Course materials&#xa;Notes, slides and&#xa;documents from&#xa;the lecturer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="130" y="195" width="370" height="150" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="✂️  Break into small pieces&#xa;Each document is cut into short,&#xa;bite-sized sections — small enough&#xa;for the AI to handle one idea at a time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="600" y="195" width="540" height="150" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="🧠  Remember each piece&#xa;Every piece is filed in a special&#xa;&quot;search memory&quot; so the AI can&#xa;find it again instantly later." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1240" y="195" width="540" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ae1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="a1" target="a2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="a2" target="a3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- STEP B — ANSWERING -->
        <mxCell id="b" value="Step B — Answering a question  (every time a student asks)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=18;spacingTop=10;fontSize=16;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="1840" height="470" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="🙋  Student asks a question&#xa;&quot;Explain normalisation in databases.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="130" y="510" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="🔎  Find the most relevant pieces&#xa;The AI searches its memory and pulls&#xa;out the handful of course-material&#xa;pieces that best match the question." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="730" y="490" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="b3" value="🥇  Pick the best of the best&#xa;A second check re-ranks the pieces&#xa;so the most useful ones are used." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1370" y="490" width="410" height="140" as="geometry" />
        </mxCell>
        <mxCell id="b4" value="✍️  Write the answer&#xa;The AI writes a clear answer using ONLY&#xa;those real course-material pieces — it is&#xa;not allowed to invent facts." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="730" y="700" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="b5" value="✅  Answer + sources shown&#xa;The student sees the answer AND&#xa;which course materials it came from." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="130" y="700" width="500" height="140" as="geometry" />
        </mxCell>

        <mxCell id="be1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="be2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="be3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1575" y="665" /><mxPoint x="1000" y="665" /></Array></mxGeometry></mxCell>
        <mxCell id="be4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;exitX=0;exitY=0.5;entryX=1;entryY=0.5" edge="1" parent="1" source="b4" target="b5"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="b_note" value="💡  The AI engine — the AI can run on two interchangeable engines: a custom-built one, or one made from popular ready-made AI toolkits (LangChain). Both follow the very same steps above; an admin can switch between them at any time." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="130" y="858" width="1650" height="48" as="geometry" />
        </mxCell>

        <mxCell id="footer" value="Why it matters:  because the AI must answer from real course pages, it stays accurate and can always show its sources." style="text;html=1;align=center;whiteSpace=wrap;fontSize=14;fontStyle=2;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="300" y="950" width="1400" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
