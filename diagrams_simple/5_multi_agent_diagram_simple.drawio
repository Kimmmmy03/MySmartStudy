<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="multiSimple" name="Multi-Agent (Simple)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="How the AI Gets Things Done Quickly — A Team of Helpers" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1400" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Instead of fetching information one piece at a time, the AI sends out a whole team — they all work at the same time, then meet back up." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="200" y="62" width="1600" height="40" as="geometry" />
        </mxCell>

        <!-- ============= COMPARISON ============= -->
        <mxCell id="cmp_box" value="Slow way  vs  fast way" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=15;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="1920" height="240" as="geometry" />
        </mxCell>

        <mxCell id="slow_title" value="❌  Slow way — one thing at a time" style="text;html=1;align=center;fontStyle=1;fontSize=15;fontColor=#7A2424" vertex="1" parent="1">
          <mxGeometry x="60" y="158" width="920" height="28" as="geometry" />
        </mxCell>
        <mxCell id="slow_seq" value="Ask for courses ………… wait&#10;Then ask for deadlines …… wait&#10;Then ask for grades ……… wait&#10;Then ask for timetable …… wait&#10;Then ask for reminders … wait&#10;&#10;Total time ≈ all the waits added up&#10;(~1.1 seconds in MySmartStudy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7A2424;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontColor=#7A2424;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="880" height="160" as="geometry" />
        </mxCell>

        <mxCell id="fast_title" value="✅  Fast way — everyone goes at once" style="text;html=1;align=center;fontStyle=1;fontSize=15;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1000" y="158" width="920" height="28" as="geometry" />
        </mxCell>
        <mxCell id="fast_seq" value="Send out 5 helpers at the same time —&#10;each grabs one piece of information.&#10;Wait once for the slowest to come back.&#10;&#10;Total time ≈ just the slowest helper&#10;(~0.2 seconds in MySmartStudy)&#10;&#10;~5× faster, same result." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=13;fontColor=#1F3A68;spacingLeft=14;spacingTop=12" vertex="1" parent="1">
          <mxGeometry x="1040" y="190" width="880" height="160" as="geometry" />
        </mxCell>

        <!-- ============= TEAMWORK EXAMPLE ============= -->
        <mxCell id="ex_box" value="Example — when a student opens the AI Companion chat" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=15;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="1920" height="610" as="geometry" />
        </mxCell>

        <!-- Boss centered top -->
        <mxCell id="boss" value="🧠  The AI&#10;&#10;&quot;I need to know about this student.&#10;Team — go fetch!&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="820" y="430" width="360" height="100" as="geometry" />
        </mxCell>

        <!-- Two notes positioned to the side WITHOUT overlapping boss or helpers -->
        <mxCell id="robust" value="What if one helper fails?&#10;&#10;If one helper can't get its&#10;answer (e.g. the timetable&#10;hasn't been uploaded yet),&#10;the others still bring back&#10;what they found.  The AI&#10;notes the gap and keeps&#10;going — the chat doesn't&#10;break." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=12;fontColor=#3D4A5C;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="280" height="220" as="geometry" />
        </mxCell>

        <mxCell id="bound" value="Safety limit&#10;&#10;If something hangs,&#10;the team is given&#10;up to 30 seconds.&#10;After that the AI&#10;returns what it has —&#10;so users don't wait&#10;forever for a stuck&#10;page." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECEFF5;strokeColor=#4A6E8C;fontSize=12;fontColor=#2E4A66;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1640" y="430" width="280" height="220" as="geometry" />
        </mxCell>

        <!-- 6 helpers in single row -->
        <mxCell id="h1" value="Helper 1&#10;&#10;&quot;What courses is&#10;this student in?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="Helper 2&#10;&#10;&quot;What deadlines&#10;are coming up?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="390" y="700" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="Helper 3&#10;&#10;&quot;How are their&#10;quiz scores?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="700" y="700" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="h4" value="Helper 4&#10;&#10;&quot;What does their&#10;class timetable&#10;look like?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1010" y="700" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="h5" value="Helper 5&#10;&#10;&quot;What tasks are&#10;still on their&#10;to-do list?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1320" y="700" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="h6" value="Helper 6&#10;&#10;&quot;What did they say&#10;in their last&#10;weekly reflection?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#1F3A68;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1630" y="700" width="280" height="130" as="geometry" />
        </mxCell>

        <!-- Combine box -->
        <mxCell id="combine" value="📦  All answers come back at the same time&#10;&#10;The AI now has a full picture of the student in one tidy package." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="540" y="880" width="920" height="100" as="geometry" />
        </mxCell>

        <!-- boss → helpers, all via a HORIZONTAL "bus" at y=575 so lines never cross helpers or notes -->
        <mxCell id="bh1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="boss" target="h1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="675" />
              <mxPoint x="220" y="675" />
            </Array>
          </mxGeometry>
