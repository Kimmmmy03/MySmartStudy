        <mxCell id="bh4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeWidth=2;strokeColor=#6B46C1" edge="1" parent="1" source="boss" target="h4">
          <mxGeometry relative="1" as="geometry">
