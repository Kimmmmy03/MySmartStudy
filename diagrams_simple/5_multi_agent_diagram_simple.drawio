        <mxCell id="hc3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeWidth=2;strokeColor=#4A6E8C" edge="1" parent="1" source="h3" target="combine">
          <mxGeometry relative="1" as="geometry">
