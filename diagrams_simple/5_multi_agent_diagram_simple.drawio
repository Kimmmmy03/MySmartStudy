        <mxCell id="w1" value="AI Companion chat — answer arrives in under a second" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#1F3A68;spacingLeft=12" vertex="1" parent="1">
