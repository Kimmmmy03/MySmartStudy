<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="aiSimple" name="AI Features (Simple)">
    <mxGraphModel dx="2020" dy="1201" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="How All the AI Features Work Together" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="1200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Every AI button goes through the same gate and shares the same &quot;brain.&quot;  The admin controls all of it." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="300" y="64" width="1400" height="28" as="geometry" />
        </mxCell>

        <!-- ROW 1 — AI FEATURES -->
        <mxCell id="r1" value="① What students and lecturers can ask the AI to do" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="1880" height="230" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="💬  Chat with a&#xa;Study Companion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="🧠  Mind-Map&#xa;Suggestions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="400" y="160" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="📅  Daily&#xa;Study Plan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="700" y="160" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="📝  Summaries,&#xa;Flashcards, Quizzes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1000" y="160" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f5" value="🎨  Image&#xa;for a Node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1300" y="160" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f6" value="📊  Suggest a Grade&#xa;for a Submission" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="100" y="250" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f7" value="🔍  Check for&#xa;Plagiarism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="400" y="250" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f8" value="📥  Import Course&#xa;from Google Site" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="700" y="250" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f9" value="📄  Course Learning&#xa;Plan from a PDF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="1000" y="250" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r1_note" value="Violet = student features&#xa;Plum = lecturer features.&#xa;Whichever button is&#xa;pressed, the next step&#xa;is always the same gate." style="text;html=1;align=left;whiteSpace=wrap;fontSize=12;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1320" y="245" width="540" height="80" as="geometry" />
        </mxCell>

        <!-- ROW 2 — THE GATE -->
        <mxCell id="gate" value="🚦 ② The Admin Gate — every AI request is checked here first&#xa;1. Is the AI switched on?      2. Is this particular feature allowed?      3. Is there daily AI budget left?&#xa;If any answer is &quot;no,&quot; the user sees a friendly &quot;AI is unavailable right now&quot; message instead." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=3;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="1880" height="110" as="geometry" />
        </mxCell>

        <!-- ROW 3 — THE SHARED BRAIN -->
        <mxCell id="r3" value="③ The shared &quot;brain&quot; — every feature reuses the same four building blocks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="1880" height="240" as="geometry" />
        </mxCell>
        <mxCell id="br1" value="📖  Reads course materials&#xa;Finds the right pages so&#xa;answers are accurate.&#xa;(see &quot;RAG&quot; diagram)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="110" y="620" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="br2" value="🕸️  Topic &amp; copy maps&#xa;Sees how topics connect&#xa;and spots copied work.&#xa;(see &quot;Knowledge Graph&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="570" y="620" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="br3" value="👥  Team of helpers&#xa;Gathers many things at&#xa;once so it stays fast.&#xa;(see &quot;Multi-Agent&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1030" y="620" width="420" height="140" as="geometry" />
        </mxCell>
        <mxCell id="br4" value="📋  Fills tidy forms&#xa;Returns neat results the&#xa;app can show as charts.&#xa;(see &quot;GAG&quot; diagram)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1490" y="620" width="400" height="140" as="geometry" />
        </mxCell>

        <!-- ROW 4 — ADMIN CONTROL + ENGINE -->
        <mxCell id="r4" value="④ The admin stays in control" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="60" y="850" width="1880" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ad1" value="🛡️  Admin dashboard&#xa;Switch all AI on/off, or turn off&#xa;just one feature — in about 30 seconds." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="110" y="905" width="560" height="115" as="geometry" />
        </mxCell>
        <mxCell id="ad2" value="📈  Watches the AI budget&#xa;Sees how much AI is being used&#xa;and sets daily limits per person." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="720" y="905" width="560" height="115" as="geometry" />
        </mxCell>
        <mxCell id="ad3" value="⚙️  Chooses the AI engine&#xa;The brain can run on a custom-built engine&#xa;OR a popular ready-made toolkit&#xa;(LangChain + CrewAI) — switchable anytime." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECE9F3;strokeColor=#7A6B98;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1330" y="905" width="560" height="115" as="geometry" />
        </mxCell>

        <!-- ARROWS -->
        <mxCell id="a_r1g" value="every request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="r1" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_gr3" value="if allowed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="gate" target="r3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_r3r4" value="controls &amp; powers" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;startArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="r3" target="r4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ROW 5 — MAY 2026 SOURCE TIERS (added in the SmartBuddy update) -->
        <mxCell id="r5" value="⑤ NEW (May 2026) — SmartBuddy chat always tells you where the answer came from" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=16;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="60" y="1080" width="1880" height="280" as="geometry" />
        </mxCell>
        <mxCell id="t1" value="🎓  Tier 1 — Course notes&#xa;Looks first in the lecturer's&#xa;own uploaded materials.&#xa;Shown as a green chip with&#xa;the document name." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#2C7A4B;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#1E5232" vertex="1" parent="1">
          <mxGeometry x="100" y="1135" width="440" height="170" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="📰  Tier 2 — Journals &amp; books&#xa;If lecturer notes don't cover it,&#xa;searches free, peer-reviewed&#xa;papers from the last 6 years&#xa;(via OpenAlex). Blue chip,&#xa;tap to open the paper." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#1A365D" vertex="1" parent="1">
          <mxGeometry x="580" y="1135" width="440" height="170" as="geometry" />
        </mxCell>
        <mxCell id="t3" value="🤖  Tier 3 — General AI knowledge&#xa;Last resort if no real source matched.&#xa;Amber chip says &quot;please verify.&quot;&#xa;The AI is no longer allowed to invent&#xa;fake citations." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCEFD8;strokeColor=#9C6A1F;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontColor=#5C3E10" vertex="1" parent="1">
          <mxGeometry x="1060" y="1135" width="440" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cta" value="📇  Plus three one-tap buttons&#xa;under every answer:&#xa;Generate Flashcards,&#xa;Make a Summary,&#xa;Build a Quiz. All saved&#xa;to AI Study Materials with&#xa;the same source label." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1540" y="1135" width="360" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a_r3r5" value="powers SmartBuddy answers" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="r3" target="r5"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="footer" value="In short:  press any AI button  →  the gate checks it  →  the shared brain does the work  →  the answer always shows its source.  The admin can switch or limit any of it." style="text;html=1;align=center;whiteSpace=wrap;fontSize=14;fontStyle=2;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="120" y="1390" width="1760" height="36" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
