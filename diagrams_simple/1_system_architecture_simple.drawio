<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="sysSimple" name="System Architecture (Simple)">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="What is MySmartStudy Made Of?" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="400" y="24" width="1200" height="44" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Three simple parts — the people who use it, the brain that does the work, and where everything is kept." style="text;html=1;align=center;whiteSpace=wrap;fontSize=15;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="1400" height="28" as="geometry" />
        </mxCell>

        <!-- LAYER 1 — PEOPLE -->
        <mxCell id="l1" value="① The people who use it" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=18;spacingTop=10;fontSize=16;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="1840" height="200" as="geometry" />
        </mxCell>
        <mxCell id="p_student" value="🎓  Students&#xa;Use a website or phone app to study, build mind maps, and ask the AI for help." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="130" y="185" width="560" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p_lecturer" value="👩‍🏫  Lecturers&#xa;Create courses, set assignments and quizzes, and let the AI help with grading." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="720" y="185" width="560" height="115" as="geometry" />
        </mxCell>
        <mxCell id="p_admin" value="🛡️  Admin&#xa;Looks after the whole platform and can switch the AI on or off." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1310" y="185" width="560" height="115" as="geometry" />
        </mxCell>

        <!-- LAYER 2 — THE BRAIN -->
        <mxCell id="l2" value="② The &quot;brain&quot; that does the work" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=18;spacingTop=10;fontSize=16;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="1840" height="320" as="geometry" />
        </mxCell>
        <mxCell id="b_server" value="🧠  The Server&#xa;Receives every request, checks who you are, and decides what to do." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="130" y="455" width="540" height="110" as="geometry" />
        </mxCell>
        <mxCell id="b_gate" value="🚦  The AI Gate&#xa;Before any AI task, it checks: is AI on? is this feature allowed? is there budget left?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="730" y="455" width="540" height="110" as="geometry" />
        </mxCell>
        <mxCell id="b_ai" value="🤖  The AI Helper&#xa;Reads course materials and writes answers, study plans and suggestions." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1330" y="455" width="540" height="110" as="geometry" />
        </mxCell>
        <mxCell id="b_note" value="💡  The AI Helper can run on two interchangeable &quot;engines&quot; that do exactly the same job:  a custom-built one,  or  one assembled from popular ready-made AI toolkits (LangChain and CrewAI).  An admin can switch between them in seconds — students and lecturers never notice the difference." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=13;fontColor=#3D4A5C;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="130" y="595" width="1740" height="100" as="geometry" />
        </mxCell>

        <!-- LAYER 3 — STORAGE -->
        <mxCell id="l3" value="③ Where information is kept" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=18;spacingTop=10;fontSize=16;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="790" width="1840" height="200" as="geometry" />
        </mxCell>
        <mxCell id="s_db" value="🗄️  Main Database&#xa;Accounts, courses, mind maps, grades — everything the app remembers." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="130" y="845" width="560" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s_search" value="🔎  Search Memory&#xa;A special store that lets the AI find the right course material fast." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="720" y="845" width="560" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s_files" value="📁  File Storage&#xa;Pictures, uploaded documents and AI-generated images." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1310" y="845" width="560" height="110" as="geometry" />
        </mxCell>

        <!-- ARROWS between layers -->
        <mxCell id="a1" value="ask" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a2" value="store &amp; fetch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;startArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="l2" target="l3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- LAYER 4 — OUTSIDE WORLD (added May 2026 for OpenAlex) -->
        <mxCell id="l4" value="④ What it talks to outside MySmartStudy" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=18;spacingTop=10;fontSize=16;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="1050" width="1840" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ext_gem" value="🌟  Google Gemini&#xa;The AI engine that writes answers,&#xa;reads PDFs, and creates pictures." style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#FDE0E0;strokeColor=#B71C1C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#7C1E1E" vertex="1" parent="1">
          <mxGeometry x="180" y="1110" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ext_oa" value="📰  OpenAlex (May 2026, new)&#xa;Free database of journals &amp; books.&#xa;SmartBuddy uses it when lecturer notes&#xa;don't cover a topic — only the last 6 years." style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#2C5282;strokeWidth=2;align=center;verticalAlign=middle;fontSize=14;fontColor=#1A365D" vertex="1" parent="1">
          <mxGeometry x="1040" y="1110" width="780" height="120" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="when it needs outside knowledge" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;startArrow=classic;strokeColor=#5A6478;strokeWidth=2.5;fontSize=12;fontColor=#3D4A5C;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="l2" target="l4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="footer" value="In short:  people ask  →  the brain checks and thinks  →  it saves and looks up information  →  the answer comes back  with its source clearly labelled." style="text;html=1;align=center;whiteSpace=wrap;fontSize=14;fontStyle=2;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="200" y="1280" width="1600" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
