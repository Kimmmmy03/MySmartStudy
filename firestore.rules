rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    //  BACKEND-ONLY SECURITY MODEL (deny-by-default)
    //
    //  Every data read/write in MySmartStudy is routed through the FastAPI
    //  backend, which uses the Firebase Admin SDK (Admin SDK BYPASSES these
    //  rules). Authorization — authentication, RBAC, and object-level
    //  ownership (IDOR) checks — is enforced there in route dependencies
    //  (see backend/app/auth.py and backend/app/authz.py).
    //
    //  Therefore the Firestore client surface is closed: no browser/mobile
    //  client may read or write Firestore directly. The single exception is
    //  `user_preferences/{uid}` (the web theme toggle), which the client SDK
    //  reads/writes for its own user only.
    //
    //  To re-open a collection for direct client access in future, add a
    //  scoped `match` ABOVE the catch-all with an explicit owner/role guard.
    // ─────────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Theme preference — the ONLY collection the web client touches directly
    // via the Firebase SDK. Each user may read/write only their own document.
    match /user_preferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Deny-by-default: all other collections are backend-only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
