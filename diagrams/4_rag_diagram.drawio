<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="rag" name="RAG (Legacy vs Framework)">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="2600" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="RAG Pipeline — Legacy hand-rolled vs LangChain framework (selected by AI_BACKEND)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="1800" height="36" as="geometry" />
        </mxCell>

        <!-- ENTRY -->
        <mxCell id="caller" value="Router calls&#10;rag_multistep.retrieve_multistep(query, course_ids, top_k)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="gate" value="ai_service.set_tracking_context()&#10;→ master switch · per-feature kill list · daily token quota" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="900" y="160" width="800" height="48" as="geometry" />
        </mxCell>

        <mxCell id="dispatch" value="if framework_enabled():&#10;    return rag_service_lc.retrieve_multistep(...)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEDB3;strokeColor=#C99A06;strokeWidth=2;fontSize=12;fontStyle=1;fontColor=#5C4400" vertex="1" parent="1">
          <mxGeometry x="1100" y="230" width="400" height="120" as="geometry" />
        </mxCell>

        <!-- legacy and framework labels for branches -->
        <mxCell id="lbl_legacy" value="AI_BACKEND=legacy" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="600" y="280" width="240" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl_framework" value="AI_BACKEND=framework" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1760" y="280" width="240" height="20" as="geometry" />
        </mxCell>

        <!-- LEFT PANEL — LEGACY -->
        <mxCell id="legacy_panel" value="Legacy path  ·  backend/app/rag_multistep.py + rag_service.py  ·  pure asyncio, no framework" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="1200" height="1100" as="geometry" />
        </mxCell>

        <mxCell id="L_decompose" value="1.  decompose_query()&#10;FAST_MODEL splits compound queries (≥ 6 words)&#10;into ≤ 3 atomic sub-questions via generate_text" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="540" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L_hyde" value="2.  HyDE if sub_q has &lt; MIN_HYDE_TOKENS&#10;FAST_MODEL writes a hypothetical answer, embed THAT&#10;via embed_texts (Gemini gemini-embedding-001, 768d)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="650" y="430" width="540" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L_overfetch" value="3.  Per-sub-query over-fetch&#10;chromadb collection.query(n_results = top_k × RAG_FETCH_RATIO)&#10;per course_id; merge + dedupe" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="80" y="560" width="1110" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L_rerank" value="4.  Cross-encoder rerank vs ORIGINAL query&#10;_rerank() loads sentence_transformers.CrossEncoder&#10;BAAI/bge-reranker-v2-m3 lazily; on load failure → embedding-score fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="80" y="690" width="1110" height="110" as="geometry" />
        </mxCell>

        <mxCell id="L_out" value="Returns:  list[{text, doc_id, doc_type, title, course_id, score}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D0D6E2;strokeColor=#3D4A5C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2D3748" vertex="1" parent="1">
          <mxGeometry x="80" y="830" width="1110" height="48" as="geometry" />
        </mxCell>

        <mxCell id="L_notes" value="Notes&#10;• Embeddings + Chroma upserts live in rag_service.index_document()&#10;• _enforce_ai_gate() called at the top of each retrieval&#10;• Pure Python — no framework, no extra LLM round trips" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=11;fontColor=#3D4A5C;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="920" width="1110" height="120" as="geometry" />
        </mxCell>

        <!-- RIGHT PANEL — FRAMEWORK -->
        <mxCell id="framework_panel" value="Framework path  ·  backend/app/rag_service_lc.py  ·  LangChain 1.x" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F0F8;strokeColor=#6B46C1;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="1320" y="380" width="1200" height="1100" as="geometry" />
        </mxCell>

        <mxCell id="F_load" value="1.  Chroma vectorstore  (langchain_chroma.Chroma)&#10;Reads the SAME per-course collection the legacy index built —&#10;LegacyCompatibleEmbeddings adapter produces vector-identical queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1360" y="430" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_multi" value="2.  MultiQueryRetriever  (when query ≥ 6 words)&#10;langchain_classic.retrievers.multi_query.MultiQueryRetriever.from_llm(FAST_MODEL)&#10;— LLM-driven decomposition; one retrieval per generated phrasing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1360" y="560" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_hyde" value="3.  HyDE for short queries  (len(query) &lt; HYDE_MIN_TOKENS)&#10;FAST_MODEL writes a hypothetical 2-3 sentence answer; the&#10;retriever searches with that text instead of the raw query" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1360" y="690" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_rerank" value="4.  ContextualCompressionRetriever&#10;wraps the base retriever with CrossEncoderReranker (top_n = top_k)&#10;model: BAAI/bge-reranker-v2-m3 via HuggingFaceCrossEncoder (cached singleton)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1360" y="820" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_out" value="Returns:  SAME list[{text, doc_id, doc_type, title, course_id, score}]&#10;UsageCallback streams token counts into ai_service._log_token_usage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D0D6E2;strokeColor=#3D4A5C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2D3748" vertex="1" parent="1">
          <mxGeometry x="1360" y="950" width="1120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="F_notes" value="Notes&#10;• Indexing is NOT reimplemented — rag_service.index_document still owns Chroma writes;&#10;  the framework path only READS via the embedding adapter.&#10;• _enforce_ai_gate() is called in rag_service_lc.retrieve() — gate stays honoured.&#10;• Token usage is captured through the LangChain UsageCallback (langchain_core.callbacks.BaseCallbackHandler)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=11;fontColor=#3D4A5C;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1360" y="1040" width="1120" height="180" as="geometry" />
        </mxCell>

        <!-- ARROWS -->
        <mxCell id="a_caller_gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="caller" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_gate_disp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate" target="dispatch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_disp_legacy" value="false" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2;fontSize=11;fontColor=#1F3A68" edge="1" parent="1" source="dispatch" target="L_decompose"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="340" y="290" /><mxPoint x="340" y="410" /></Array></mxGeometry></mxCell>
        <mxCell id="a_disp_fw" value="true" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2;fontSize=11;fontColor=#4C2F87" edge="1" parent="1" source="dispatch" target="F_load"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1900" y="290" /><mxPoint x="1900" y="410" /></Array></mxGeometry></mxCell>

        <!-- legacy vertical chain -->
        <mxCell id="aL1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#2C5282;strokeWidth=2" edge="1" parent="1" source="L_decompose" target="L_hyde"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aL2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2" edge="1" parent="1" source="L_hyde" target="L_overfetch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aL3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="L_overfetch" target="L_rerank"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aL4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#3D4A5C;strokeWidth=2" edge="1" parent="1" source="L_rerank" target="L_out"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- framework vertical chain -->
        <mxCell id="aF1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="F_load" target="F_multi"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aF2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="F_multi" target="F_hyde"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aF3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="F_hyde" target="F_rerank"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aF4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#3D4A5C;strokeWidth=2" edge="1" parent="1" source="F_rerank" target="F_out"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- footer -->
        <mxCell id="footer" value="Both paths preserve identical return shape so routers do not change.  Switch with: gcloud run services update mysmartstudy-api --update-env-vars AI_BACKEND=framework" style="text;html=1;align=center;fontSize=11;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="1510" width="2480" height="24" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
