<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="gag" name="GAG Pipeline">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MySmartStudy — GAG (Generation-Augmented Generation) Service" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="1400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="GAG = RAG chunks + Knowledge Graph + multi-agent context  →  structured artifact (not free text).  Every input box connects to its generator via a vertical bus." style="text;html=1;align=center;whiteSpace=wrap;fontSize=12;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="400" y="60" width="1800" height="30" as="geometry" />
        </mxCell>

        <!-- ============ INPUTS ============ -->
        <mxCell id="bg_inputs" value="Inputs into GAG" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="2520" height="220" as="geometry" />
        </mxCell>
        <mxCell id="in_rag" value="RAG chunks&#10;rag_service.retrieve&#10;&#10;text, doc_id, doc_type,&#10;title, course_id, score" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="in_kg" value="Concept subgraph&#10;knowledge_graph_service.&#10;query_related_concepts&#10;&#10;nodes + edges + relations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="360" y="150" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="in_student" value="Student bundle&#10;(multi-agent fan-out)&#10;&#10;quiz_scores · grades&#10;weak_topics · timetables&#10;deadlines · learning_style" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="660" y="150" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="in_assign" value="Assignment context&#10;&#10;submission content (txt/PDF/map)&#10;rubric criteria + maxPoints&#10;class_stats : mean, median, count" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="960" y="150" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="in_map" value="Mind map context&#10;&#10;existing nodes (label)&#10;map title, task_description" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1260" y="150" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="in_simgraph" value="Similarity graph (plagiarism)&#10;&#10;nodes: studentId, name&#10;edges: {src, tgt, similarity}&#10;clusters via connected comp." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1540" y="150" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="in_kb" value="Knowledge bases (system prompts)&#10;ai_service.KNOWLEDGE_BASES&#10;&#10;study_plan · grading · plagiarism&#10;rag_companion · study_materials" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1840" y="150" width="320" height="160" as="geometry" />
        </mxCell>

        <!-- ============ GENERATORS (single row, 4 columns) ============ -->
        <mxCell id="gag_box" value="gag_service.py  —  4 generator functions  (all call ai_service.generate_json)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F0E9F8;strokeColor=#6B46C1;strokeWidth=3;verticalAlign=top;fontSize=14;fontStyle=1;fontColor=#4C2F87;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="2520" height="420" as="geometry" />
        </mxCell>

        <mxCell id="g1" value="generate_study_plan_artifact()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="580" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g1_in" value="Inputs:&#10; student_context, rag_chunks per course,&#10; deadlines[], exam_info?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="90" y="480" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g1_out" value="Output JSON:&#10;{ recommendations: [{&#10;   course, topic, priority,&#10;   suggested_time, reason,&#10;   estimated_time,&#10;   difficulty_rating (1-5),&#10;   resource_links: [...],&#10;   suggested_activities: [...]&#10;  }],&#10;  daily_schedule_summary,&#10;  motivational_message }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="380" y="480" width="270" height="220" as="geometry" />
        </mxCell>
        <mxCell id="g1_rules" value="Rules&#10;• Sessions in FREE gaps (no overlap)&#10;• Chronological by suggested_time&#10;• difficulty from past performance&#10;• KB: study_plan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=2;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="90" y="610" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="g2" value="generate_grading_report()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="680" y="430" width="580" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g2_in" value="Inputs:&#10; submission_content, rubric : Criterion[],&#10; rag_chunks, class_stats" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="690" y="480" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g2_out" value="Output JSON:&#10;{ recommended_grade: 0-100,&#10;  criterion_scores: {name: score},&#10;  justification, confidence: 0-1,&#10;  comparative_analysis,&#10;  improvement_suggestions: [{&#10;    criterion, suggestion,&#10;    resource_link&#10;  }] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="980" y="480" width="270" height="220" as="geometry" />
        </mxCell>
        <mxCell id="g2_rules" value="Rules&#10;• Auto-fill resource_link from sources&#10;• KB: grading&#10;• tutorial-type submissions only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=2;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="690" y="610" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="g3" value="generate_graph_suggestions()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1280" y="430" width="580" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g3_in" value="Inputs:&#10; map_nodes[], map_edges[],&#10; rag_chunks, concept_subgraph,&#10; map_title, task_description" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1290" y="480" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g3_out" value="Output JSON:&#10;{ suggestions: [{&#10;    label, description,&#10;    parent_label (EXACT),&#10;    source: {...},&#10;    graph_connections: [labels]&#10;  }],&#10;  related_concepts_graph: {&#10;    nodes, edges } }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1580" y="480" width="270" height="220" as="geometry" />
        </mxCell>
        <mxCell id="g3_rules" value="Rules&#10;• Grounded in materials / KG&#10;• Source attribution required&#10;• parent_label must match exactly&#10;• KB: SmartBuddy for Mind Maps&#10;• temperature = 0.5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=2;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1290" y="610" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="g4" value="generate_plagiarism_network_report()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1880" y="430" width="660" height="40" as="geometry" />
        </mxCell>
        <mxCell id="g4_in" value="Inputs:&#10; similarity_graph,&#10; clusters: [[studentId, …]],&#10; submission_contents: {sid: text}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1890" y="480" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="g4_out" value="Output JSON:&#10;{ flagged_clusters: [{&#10;    students, max_similarity,&#10;    analysis  // detailed }],&#10;  summary }&#10;+ network_graph (re-attached)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="2200" y="480" width="330" height="220" as="geometry" />
        </mxCell>
        <mxCell id="g4_rules" value="Rules&#10;• Classifies per cluster&#10;  (shared content, coincidental vs intentional, severity)&#10;• KB: plagiarism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=2;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1890" y="610" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- ============ LLM CORE (full-width bar) ============ -->
        <mxCell id="llm_core" value="ai_service.generate_json()   —   Gemini SMART_MODEL  (gemini-2.5-flash)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=3;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="2520" height="60" as="geometry" />
        </mxCell>
        <mxCell id="llm_steps" value="Inside generate_json:&#10;1) Compose system_instruction = KNOWLEDGE_BASES[domain]   ·   2) Build user prompt with safe_truncate(submission, 6000 tokens)   ·   3) await asyncio.to_thread(client.models.generate_content)&#10;4) Strip ```json fences   ·   5) Retry once on JSONDecodeError / network error   ·   6) _log_token_usage(total_tokens) increments aiUsageSummary + aiDailyUsage in Firestore." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="925" width="2520" height="55" as="geometry" />
        </mxCell>

        <!-- ============ POST-PROCESS & CONSUMERS ============ -->
        <mxCell id="bg_post" value="Post-processing &amp; consumers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="1000" width="2520" height="300" as="geometry" />
        </mxCell>

        <mxCell id="post_enrich" value="Enrichment (defensive)&#10;&#10;• Fill missing resource_links / sources&#10;  from rag_service.format_citations()&#10;• Reattach network_graph to plagiarism&#10;• Ensure 'parent_label' exists in map_nodes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="1050" width="380" height="200" as="geometry" />
        </mxCell>

        <mxCell id="post_persist" value="Persist to Firestore" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=center;verticalAlign=top;fontStyle=1;fontSize=12;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="500" y="1050" width="380" height="40" as="geometry" />
        </mxCell>
        <mxCell id="post_persist_list" value="aiStudyPlans (keyed by userId+date)&#10;aiGradeRecommendations (keyed by submissionId)&#10;aiPlagiarismReports (single + network)&#10;aiMapAnalysisCache (suggestAll)&#10;aiNodeRecsCache (single-node recs)&#10;aiDailyGuideCache (24h TTL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=6;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="500" y="1100" width="380" height="150" as="geometry" />
        </mxCell>

        <!-- 4 consumers in a single row, no overlap with arrows -->
        <mxCell id="cons_studyplan" value="ai_study_plan.daily_guide&#10;&#10;Renders schedule on Student&#10;dashboard; inserts plan items&#10;into planner." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="920" y="1050" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cons_grading" value="ai_grading.recommend&#10;&#10;Lecturer UI: recommended grade,&#10;criterion bar chart, comparative&#10;paragraph, clickable improvement-&#10;source links." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="920" y="1180" width="380" height="120" as="geometry" />
        </mxCell>

        <mxCell id="cons_buddy" value="ai_mindmap_buddy.suggest_all&#10;&#10;Map editor draws suggested nodes,&#10;links to parent_label, opens&#10;source preview." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1340" y="1050" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cons_plag" value="ai_plagiarism.analyze_network&#10;&#10;Force-directed graph in lecturer&#10;analytics — clusters coloured,&#10;sidebar shows narrative + students." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="1340" y="1180" width="380" height="120" as="geometry" />
        </mxCell>

        <mxCell id="gag_why" value="Why GAG?&#10;&#10;• Plain LLM = free text. GAG = structured&#10;  artifact, directly renderable by the UI.&#10;• Combines RAG (text grounding) + KG&#10;  (relational grounding) + pedagogical&#10;  schema (rubric, difficulty rating)&#10;  in a single call.&#10;• Output is JSON the frontend can trust&#10;  and route (charts, links, graph viz)." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=10;fontColor=#3D4A5C;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="1760" y="1050" width="360" height="160" as="geometry" />
        </mxCell>
        <mxCell id="gag_note" value="GAG never bypasses the AI gate.&#10;set_tracking_context() runs in the consumer router&#10;before gag_service is invoked, so disabling&#10;'study_plan' / 'grading' / 'plagiarism' /&#10;'mindmap_buddy' short-circuits with HTTP 503." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECEFF5;strokeColor=#4A6E8C;fontSize=10;fontColor=#2E4A66;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="2150" y="1050" width="380" height="160" as="geometry" />
        </mxCell>

        <!-- ============ ARROWS WITH WAYPOINTS ============ -->
        <!-- Inputs → generators via vertical bus at y=350 (between input row and generator row) -->
        <!-- RAG → all 3 generators that use it (g1, g2, g3) -->
        <mxCell id="ae1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="in_rag" target="g1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="200" y="340" /><mxPoint x="254" y="340" /></Array></mxGeometry></mxCell>
        <mxCell id="ae2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="in_rag" target="g2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="200" y="345" /><mxPoint x="854" y="345" /></Array></mxGeometry></mxCell>
        <mxCell id="ae3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.3;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="in_rag" target="g3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="200" y="350" /><mxPoint x="1454" y="350" /></Array></mxGeometry></mxCell>

        <!-- KG → g3 -->
        <mxCell id="ae4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.6;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="in_kg" target="g3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="490" y="355" /><mxPoint x="1628" y="355" /></Array></mxGeometry></mxCell>

        <!-- Student → g1 -->
        <mxCell id="ae5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.7;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2" edge="1" parent="1" source="in_student" target="g1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="790" y="360" /><mxPoint x="486" y="360" /></Array></mxGeometry></mxCell>

        <!-- Assignment → g2 -->
        <mxCell id="ae6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="in_assign" target="g2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1090" y="365" /><mxPoint x="970" y="365" /></Array></mxGeometry></mxCell>

        <!-- Map → g3 -->
        <mxCell id="ae7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.4;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2" edge="1" parent="1" source="in_map" target="g3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1380" y="370" /><mxPoint x="1512" y="370" /></Array></mxGeometry></mxCell>

        <!-- Similarity → g4 -->
        <mxCell id="ae8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.4;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="in_simgraph" target="g4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1670" y="375" /><mxPoint x="2144" y="375" /></Array></mxGeometry></mxCell>

        <!-- KB → llm_core via right margin bus -->
