<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="gag" name="GAG (Legacy vs Framework)">
    <mxGraphModel dx="2200" dy="1300" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="2600" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="GAG — Structured Output Generation  ·  Legacy `generate_json` vs LangChain `with_structured_output`" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="2200" height="36" as="geometry" />
        </mxCell>

        <!-- ROUTERS that call GAG -->
        <mxCell id="callers" value="Routers that call GAG&#10;ai_study_plan · ai_grading · ai_mindmap_buddy · ai_plagiarism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dispatch" value="gag_service.generate_*()&#10;if framework_enabled():&#10;    return gag_service_lc.generate_*(...)&#10;# else fall through to the legacy generate_json branch" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEDB3;strokeColor=#C99A06;strokeWidth=2;fontSize=11;fontStyle=1;fontColor=#5C4400" vertex="1" parent="1">
          <mxGeometry x="980" y="170" width="640" height="120" as="geometry" />
        </mxCell>

        <!-- LEFT PANEL — LEGACY -->
        <mxCell id="legacy_panel" value="Legacy path  ·  backend/app/gag_service.py + ai_service.generate_json" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="1200" height="900" as="geometry" />
        </mxCell>

        <mxCell id="L_prompt" value="1.  Build prompt with the system_instruction (KNOWLEDGE_BASES)&#10;Each generator concatenates a long JSON-schema-by-example string&#10;e.g. 'Return JSON: {{recommendations: [...], ...}}'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="1110" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L_call" value="2.  ai_service.generate_json(prompt, temperature)&#10;Calls google-genai client.models.generate_content&#10;then strips Markdown fences, json.loads(), retries once on JSONDecodeError" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="1110" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L_validate" value="3.  Hand-coded validation + defensive enrichment&#10;Caller checks keys, fills missing resource_link from RAG sources,&#10;clamps numeric ranges, drops empty entries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="1110" height="100" as="geometry" />
        </mxCell>

        <mxCell id="L_out" value="Returns: dict (the four artifact shapes — study plan, grading report, mind-map suggestions, plagiarism report)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D0D6E2;strokeColor=#3D4A5C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2D3748" vertex="1" parent="1">
          <mxGeometry x="80" y="770" width="1110" height="56" as="geometry" />
        </mxCell>

        <mxCell id="L_notes" value="Risk surface&#10;• Schema lives in prose inside the prompt — drift between prompt and consumer is silent.&#10;• On bad JSON, generate_json retries once with the SAME prompt — no schema feedback.&#10;• Field-level types not enforced; downstream code must validate by hand." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=11;fontColor=#3D4A5C;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="850" width="1110" height="120" as="geometry" />
        </mxCell>

        <!-- RIGHT PANEL — FRAMEWORK -->
        <mxCell id="framework_panel" value="Framework path  ·  backend/app/gag_service_lc.py  ·  LangChain `with_structured_output` (Pydantic schemas)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F0F8;strokeColor=#6B46C1;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="1320" y="320" width="1200" height="900" as="geometry" />
        </mxCell>

        <mxCell id="F_schema" value="1.  Typed Pydantic schemas live in code, NOT in the prompt&#10;_StudyPlanArtifact, _GradingReport, _MindMapSuggestions, _PlagiarismNetworkReport&#10;Optional fields default; numeric ranges enforced via Field(ge=, le=)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1360" y="380" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_bind" value="2.  llm.with_structured_output(SchemaCls).with_config({callbacks: [UsageCallback()]})&#10;LangChain attaches a tool / function-call descriptor to the Gemini request,&#10;so the model is constrained to fill THIS schema or fail validation deterministically" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1360" y="510" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_invoke" value="3.  await asyncio.to_thread(chain.invoke, prompt)&#10;Prompt is just the inputs (no schema-by-example noise).&#10;Returns a typed Pydantic instance; .model_dump() converts to the same dict shape." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1360" y="640" width="1120" height="100" as="geometry" />
        </mxCell>

        <mxCell id="F_out" value="Returns: SAME dict shape as legacy.  + UsageCallback writes token totals into aiUsageSummary / aiDailyUsage." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D0D6E2;strokeColor=#3D4A5C;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2D3748" vertex="1" parent="1">
          <mxGeometry x="1360" y="770" width="1120" height="56" as="geometry" />
        </mxCell>

        <mxCell id="F_notes" value="Why this is better&#10;• Schema is a Python class — IDE autocomplete, mypy, tests.&#10;• Schema drift is impossible: change the Pydantic field, the LLM is told.&#10;• Field types enforced by LangChain before the dict ever reaches the router.&#10;• Token accounting is wired through the same _log_token_usage as legacy — admin dashboards stay accurate." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=11;fontColor=#3D4A5C;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="1360" y="850" width="1120" height="160" as="geometry" />
        </mxCell>

        <!-- ARROWS -->
        <mxCell id="a_call_disp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="callers" target="dispatch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_disp_L" value="legacy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2;fontSize=11;fontColor=#1F3A68" edge="1" parent="1" source="dispatch" target="L_prompt"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="380" y="230" /><mxPoint x="380" y="360" /></Array></mxGeometry></mxCell>
        <mxCell id="a_disp_F" value="framework" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2;fontSize=11;fontColor=#4C2F87" edge="1" parent="1" source="dispatch" target="F_schema"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1900" y="230" /><mxPoint x="1900" y="360" /></Array></mxGeometry></mxCell>

        <!-- legacy chain -->
        <mxCell id="aL1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="L_prompt" target="L_call"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aL2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="L_call" target="L_validate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aL3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#3D4A5C;strokeWidth=2" edge="1" parent="1" source="L_validate" target="L_out"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- framework chain -->
        <mxCell id="aF1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="F_schema" target="F_bind"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aF2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="F_bind" target="F_invoke"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="aF3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#3D4A5C;strokeWidth=2" edge="1" parent="1" source="F_invoke" target="F_out"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
