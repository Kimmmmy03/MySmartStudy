<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="aiInteraction" name="AI Features Interaction">
    <mxGraphModel dx="2600" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="2000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MySmartStudy — How all AI features talk to each other  (Routers ↔ Services ↔ Data)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="700" y="20" width="1700" height="36" as="geometry" />
        </mxCell>

        <!-- ============== ROW 1: AI ROUTERS ============== -->
        <mxCell id="row_routers" value="AI Feature Routers — backend/app/routers/ai_*.py" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="2920" height="260" as="geometry" />
        </mxCell>

        <mxCell id="r_companion" value="ai_companion&#10;&#10;/api/ai/companion/&#10;  chat / chat-stream&#10;  history&#10;  learning-profile&#10;  assess-style&#10;&#10;Audience: Student" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
