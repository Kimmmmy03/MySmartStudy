          <mxGeometry x="2380" y="120" width="270" height="210" as="geometry" />
        </mxCell>
        <mxCell id="r_admin" value="admin / rag_admin&#10;&#10;/api/admin/ai/&#10;  master-switch&#10;  disabled-features&#10;/api/rag-admin/&#10;  reindex/{cid}&#10;  build-kg/{cid}&#10;&#10;public /api/ai/status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D0D6E2;strokeColor=#3D4A5C;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2D3748" vertex="1" parent="1">
          <mxGeometry x="2670" y="120" width="270" height="210" as="geometry" />
        </mxCell>

        <!-- ============== ROW 2: GATEKEEPER (full-width bar) ============== -->
        <mxCell id="gate_box" value="GATEKEEPER  —  ai_service.set_tracking_context(user_id, feature)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=3;align=center;verticalAlign=top;fontSize=14;fontStyle=1;fontColor=#3D4A5C;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="2920" height="44" as="geometry" />
        </mxCell>
        <mxCell id="gate_body" value="1)  _enforce_ai_gate(feature)  →  Firestore aiConfig/global  →  if not aiEnabled  →  503    ·    if feature in disabledFeatures  →  503&#10;2)  daily quota check  →  aiUserSettings  →  aiConfig.dailyTokenLimit  →  DEFAULT 50 000     ·    if today's used ≥ limit  →  429&#10;3)  set context-vars (_tracking_user, _tracking_feature) — subsequent Gemini calls increment aiUsageSummary + aiDailyUsage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6478;align=left;verticalAlign=middle;fontSize=11;spacingLeft=14;spacingTop=4;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="2920" height="80" as="geometry" />
        </mxCell>

        <!-- Routers → gate (straight down, each enters at a different x) -->
        <mxCell id="rg1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.066;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="r_companion" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.166;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="r_buddy" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.266;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="r_studyplan" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.366;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="r_materials" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.466;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="r_images" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.566;entryY=0;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="r_grading" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.666;entryY=0;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="r_plag" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.766;entryY=0;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="r_import" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.866;entryY=0;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="r_clp" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="rg10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.966;entryY=0;endArrow=classic;strokeColor=#3D4A5C;strokeWidth=2" edge="1" parent="1" source="r_admin" target="gate_box"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============== ROW 3: SHARED PRIMITIVES ============== -->
        <mxCell id="row_prim" value="Shared AI primitives — every router pulls from this layer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=14;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="2920" height="290" as="geometry" />
        </mxCell>

        <mxCell id="p_multi" value="multi_agent.fan_out()&#10;&#10;Parallel data gathering&#10;asyncio.gather + 30 s timeout&#10;Failure-isolated agents" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="580" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_rag" value="rag_service + rag_multistep&#10;&#10;Chunk · Embed · Retrieve&#10;Decompose · HyDE · Rerank&#10;ChromaDB per-course" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="430" y="580" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_kg" value="knowledge_graph_service&#10;&#10;Concept graphs (Firestore)&#10;BFS subgraph queries&#10;Similarity graph (cosine)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="780" y="580" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_gag" value="gag_service&#10;&#10;Structured-artifact generators&#10;(study_plan, grading,&#10; mindmap-graph, plagiarism)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1130" y="580" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_ai" value="ai_service&#10;&#10;Gemini wrapper&#10;generate_text · generate_json&#10;chat_completion · embed&#10;SAFETY · token logging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1480" y="580" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_cache" value="Result caches (Firestore)&#10;&#10;aiDailyGuideCache · aiMapAnalysisCache&#10;aiNodeRecsCache · aiSuggestAllCache&#10;aiExamPlanCache · aiTimetableCache&#10;aiImportCache · aiImageCache&#10;aiCompanionQuestionCache&#10;aiImageQuotas (2 / day)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=6;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1830" y="580" width="370" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_sim" value="similarity.py&#10;&#10;Pairwise cosine&#10;Connected-components clustering" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="2230" y="580" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p_audit" value="audit.audit_log&#10;&#10;Append to auditLogs:&#10;ai_grade.apply, plagiarism.flag,&#10;admin.master_switch_toggle, …" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D0D6E2;strokeColor=#3D4A5C;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2D3748" vertex="1" parent="1">
          <mxGeometry x="2580" y="580" width="320" height="170" as="geometry" />
        </mxCell>

        <!-- gate → primitives (each enters one box; lines spread along width via different exit X on the gate bar) -->
        <mxCell id="gp1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.08;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_multi"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.2;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_rag"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.32;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_kg"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.44;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_gag"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.56;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_ai"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.68;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2;dashed=1" edge="1" parent="1" source="gate_body" target="p_cache"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.82;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_sim"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gp8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.94;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#3D4A5C;strokeWidth=2" edge="1" parent="1" source="gate_body" target="p_audit"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============== DEPENDENCY NOTE BAR ============== -->
        <mxCell id="row_dep" value="Internal dependencies between primitives" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="2920" height="120" as="geometry" />
        </mxCell>
        <mxCell id="dep_text" value="rag_multistep → rag_service (retrieve, embed_texts, _rerank)            rag_service.embed_texts → ai_service._get_client (Gemini embeddings)&#10;knowledge_graph_service → rag_service (chunks + embed_texts) and ai_service.generate_json (concept extraction)&#10;gag_service → rag_service.format_context / format_citations  +  ai_service.generate_json&#10;ALL Gemini calls in ai_service write to aiUsageSummary (lifetime) and aiDailyUsage (quota) via _log_token_usage().&#10;The AI gate (_enforce_ai_gate) is checked again inside _get_client() — belt-and-braces for paths that bypass set_tracking_context (KG, site-importer, CLP)." style="text;html=1;align=left;verticalAlign=top;fontSize=11;spacingLeft=18;spacingTop=8;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="880" width="2920" height="90" as="geometry" />
        </mxCell>

        <!-- ============== ROW 4: DATA STORES ============== -->
        <mxCell id="row_data" value="Backing data stores" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="990" width="2920" height="320" as="geometry" />
        </mxCell>

        <mxCell id="d_firestore" value="Firebase Firestore&#10;&#10;Operational + AI metadata&#10;users, courses, assignments,&#10;submissions, quizzes, modules,&#10;announcements, discussions,&#10;messages, reminders, badges,&#10;peerReviews, attendance, rubrics&#10;&#10;AI: aiChatHistory, learningProfiles,&#10;aiPlagiarismReports, aiGradeRecs,&#10;aiStudyPlans, aiMindmapBuddyMemory,&#10;ragIndexState, knowledgeGraphs,&#10;aiConfig, aiDailyUsage, auditLogs&#10;+ all AI result caches" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=10;spacingLeft=16;spacingTop=12;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="80" y="1030" width="380" height="260" as="geometry" />
        </mxCell>

        <mxCell id="d_chroma" value="ChromaDB&#10;persistent vector store&#10;&#10;backend/vector_store/&#10;course_{cid} collection&#10;HNSW · cosine · 768-dim" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=10;spacingLeft=16;spacingTop=12;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="490" y="1030" width="320" height="260" as="geometry" />
        </mxCell>

        <mxCell id="d_files" value="File storage&#10;&#10;backend/uploads/&#10;PDF submissions · Avatars&#10;Generated images · CLP PDFs" style="shape=folder;whiteSpace=wrap;html=1;fillColor=#ECEFF5;strokeColor=#4A6E8C;tabWidth=80;tabHeight=18;align=left;verticalAlign=top;fontSize=10;spacingLeft=16;spacingTop=26;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="840" y="1030" width="280" height="260" as="geometry" />
        </mxCell>

        <mxCell id="d_gemini" value="Google Gemini API&#10;&#10;SMART = gemini-2.5-flash&#10;FAST  = gemini-2.5-flash-lite&#10;EMBED = gemini-embedding-001&#10;IMAGE = Imagen-3 (via SDK)&#10;&#10;Wrapped by ai_service.&#10;Tokens accounted per feature." style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=10;spacingLeft=24;spacingTop=14;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1150" y="1030" width="340" height="260" as="geometry" />
        </mxCell>

        <mxCell id="d_reranker" value="Cross-Encoder Reranker&#10;BAAI/bge-reranker-v2-m3&#10;(local · CPU · 80MB)&#10;Lazy singleton" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1520" y="1030" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="d_firebase" value="Firebase Auth&#10;ID token verify per request" style="shape=cloud;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=24;spacingTop=14;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1520" y="1170" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- Primitives → stores via vertical bus at y=800 -->
        <mxCell id="ps1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="p_rag" target="d_chroma"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="590" y="780" /><mxPoint x="650" y="780" /></Array></mxGeometry></mxCell>
