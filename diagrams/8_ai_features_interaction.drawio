<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="aifeats" name="AI Features Interaction">
    <mxGraphModel dx="2400" dy="1300" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="2800" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="AI Features × Patterns × Backends  ·  How AI_BACKEND={legacy | framework} reroutes every feature" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="2600" height="36" as="geometry" />
        </mxCell>

        <!-- ROW 1: USER REQUEST -->
        <mxCell id="req" value="POST /api/ai/* — any AI router endpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1100" y="80" width="600" height="50" as="geometry" />
        </mxCell>

        <!-- ROW 2: GATE -->
        <mxCell id="gate" value="ai_service.set_tracking_context(user_id, feature)  →  master switch · per-feature kill list · daily token quota" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="700" y="155" width="1400" height="48" as="geometry" />
        </mxCell>

        <!-- ROW 3: DISPATCH -->
        <mxCell id="dispatch" value="In every public AI service function:&#10;if framework_enabled():  return *_lc.* (...)   else: run legacy" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEDB3;strokeColor=#C99A06;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5C4400" vertex="1" parent="1">
          <mxGeometry x="1100" y="225" width="600" height="80" as="geometry" />
        </mxCell>

        <!-- LEGACY PANEL -->
        <mxCell id="L_panel" value="AI_BACKEND=legacy  ·  hand-rolled" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="1260" height="1280" as="geometry" />
        </mxCell>

        <mxCell id="L_h_feat" value="Feature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=center;fontStyle=1;fontSize=12;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="280" height="36" as="geometry" />
        </mxCell>
        <mxCell id="L_h_imp" value="Implementation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=center;fontStyle=1;fontSize=12;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="380" y="380" width="940" height="36" as="geometry" />
        </mxCell>

        <!-- legacy rows -->
        <mxCell id="L_chat_f" value="Companion chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=center;fontSize=11;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L_chat_i" value="multi_agent.fan_out (6 Firestore _ctx_*) → rag_multistep.retrieve_multistep → ai_service.chat_completion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="380" y="430" width="940" height="60" as="geometry" />
        </mxCell>

        <mxCell id="L_rag_f" value="RAG retrieval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=center;fontSize=11;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L_rag_i" value="rag_service.retrieve() — decompose → HyDE → chroma.query × course_ids → _rerank (BGE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="380" y="510" width="940" height="60" as="geometry" />
        </mxCell>

        <mxCell id="L_kg_f" value="Knowledge graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=center;fontSize=11;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="590" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L_kg_i" value="knowledge_graph_service.build_course_graph — generate_json prompt asks for {concepts[], relationships[]}, persists to Firestore" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="380" y="590" width="940" height="60" as="geometry" />
        </mxCell>

        <mxCell id="L_gag_f" value="GAG (study plan, mind-map, plagiarism)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=center;fontSize=11;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="670" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L_gag_i" value="gag_service.generate_*  →  ai_service.generate_json  (JSON-by-example prompt + fence strip + retry)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="380" y="670" width="940" height="60" as="geometry" />
        </mxCell>

        <mxCell id="L_grade_f" value="AI Grading" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=center;fontSize=11;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="750" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="L_grade_i" value="gag_service.generate_grading_report — single LLM call producing the grading JSON, then defensive enrichment of resource_links from RAG sources" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2C5282;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="380" y="750" width="940" height="60" as="geometry" />
        </mxCell>

        <!-- FRAMEWORK PANEL -->
        <mxCell id="F_panel" value="AI_BACKEND=framework  ·  LangChain + CrewAI" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F0F8;strokeColor=#6B46C1;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="1340" y="340" width="1420" height="1280" as="geometry" />
        </mxCell>

        <mxCell id="F_h_feat" value="Feature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=center;fontStyle=1;fontSize=12;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1380" y="380" width="280" height="36" as="geometry" />
        </mxCell>
        <mxCell id="F_h_imp" value="Framework implementation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=center;fontStyle=1;fontSize=12;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1680" y="380" width="1040" height="36" as="geometry" />
        </mxCell>

        <mxCell id="F_chat_f" value="Companion chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=center;fontSize=11;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1380" y="430" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="F_chat_i" value="Same as legacy — async fan-out kept on purpose (Firestore I/O, not reasoning). Planning-intent detector delegates to study-plan GAG when matched." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1680" y="430" width="1040" height="60" as="geometry" />
        </mxCell>

        <mxCell id="F_rag_f" value="RAG retrieval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=center;fontSize=11;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1380" y="510" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="F_rag_i" value="rag_service_lc.retrieve — Chroma + MultiQueryRetriever (FAST_MODEL) + ContextualCompressionRetriever wrapping CrossEncoderReranker (BGE) — HyDE for terse queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1680" y="510" width="1040" height="60" as="geometry" />
        </mxCell>

        <mxCell id="F_kg_f" value="Knowledge graph" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=center;fontSize=11;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1380" y="590" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="F_kg_i" value="knowledge_graph_service_lc.build_course_graph — langchain_experimental.LLMGraphTransformer with allowed_nodes / allowed_relationships, output mapped to Firestore shape" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1680" y="590" width="1040" height="60" as="geometry" />
        </mxCell>

        <mxCell id="F_gag_f" value="GAG (study plan, mind-map, plagiarism)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=center;fontSize=11;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1380" y="670" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="F_gag_i" value="gag_service_lc.generate_* — llm.with_structured_output(PydanticSchema).with_config({callbacks: [UsageCallback()]}) — schema enforced by LangChain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1680" y="670" width="1040" height="60" as="geometry" />
        </mxCell>

        <mxCell id="F_grade_f" value="AI Grading (adaptive)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=center;fontSize=11;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1380" y="750" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="F_grade_i" value="crew_service._is_complex_submission:&#10;  · short / few criteria  → gag_service_lc.generate_grading_report (single LLM call, ~3s)&#10;  · long / many criteria → CrewAI Crew(Analyst on FAST, Grader on SMART; output_pydantic=_GradingReport)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=10;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1680" y="750" width="1040" height="90" as="geometry" />
        </mxCell>

        <!-- SHARED PLUMBING -->
        <mxCell id="shared" value="Shared on BOTH paths (defined in ai_service.py + ai_framework.py)&#10;• Firestore collections: aiUsageSummary, aiDailyUsage, AI_CONFIG (master switch + kill list + per-user/global token caps)&#10;• Per-course ChromaDB collection 'course_{cid}' on disk in /vector_store&#10;• Reranker: BAAI/bge-reranker-v2-m3 (sentence_transformers locally / HuggingFaceCrossEncoder in framework)&#10;• Embedding: Gemini gemini-embedding-001 @ 768-d  ·  LegacyCompatibleEmbeddings adapter makes legacy + framework vectors interoperable&#10;• Token accounting:  _log_token_usage(total_tokens) is called the same way in both paths (UsageCallback for LangChain, manual for legacy)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF5;strokeColor=#4A6E8C;strokeWidth=2;align=left;verticalAlign=top;fontSize=11;spacingLeft=14;spacingTop=10;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="2720" height="170" as="geometry" />
        </mxCell>

        <!-- SWITCHING -->
        <mxCell id="switch" value="How to flip the production backend  (no Docker rebuild)&#10;gcloud run services update mysmartstudy-api --region asia-southeast1 --update-env-vars AI_BACKEND=framework&#10;…and to roll back: same command with AI_BACKEND=legacy.  ~10 seconds either way." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;fontColor=#5C4400;align=left;spacingLeft=14;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="1060" width="2720" height="140" as="geometry" />
        </mxCell>

        <!-- ARROWS to dispatch + panels -->
        <mxCell id="a_req_gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="req" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_gate_disp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate" target="dispatch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_disp_L" value="legacy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2;fontSize=11;fontColor=#1F3A68" edge="1" parent="1" source="dispatch" target="L_panel"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="670" y="265" /></Array></mxGeometry></mxCell>
        <mxCell id="a_disp_F" value="framework" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2;fontSize=11;fontColor=#4C2F87" edge="1" parent="1" source="dispatch" target="F_panel"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="2050" y="265" /></Array></mxGeometry></mxCell>

        <!-- ============================================================ -->
        <!-- MAY 2026 — SmartBuddy three-tier source pipeline             -->
        <!-- ============================================================ -->
        <mxCell id="tier_header" value="May 2026 update — SmartBuddy chat (/ai/mindmap-buddy/chat) + AI Study Materials by topic (/ai/study-materials/generate-by-topic) now branch through a three-tier source pipeline.&#10;Tier is decided per-request and exposed in the response as evidence_level + sources[] + suggested_actions[]." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8CC;strokeColor=#B45309;strokeWidth=2;align=left;verticalAlign=top;fontSize=12;spacingLeft=14;spacingTop=10;fontStyle=1;fontColor=#7C3A09" vertex="1" parent="1">
          <mxGeometry x="40" y="1230" width="2720" height="62" as="geometry" />
        </mxCell>
        <mxCell id="tier_course" value="🎓  Tier 1 — Course RAG&#10;rag_multistep.retrieve_multistep over the student's enrolled courses.&#10;Chunks with cosine score ≥ 0.40 → strong_course.&#10;Sources: {tier:'course', title, doc_type, course_id, doc_id, score}.&#10;Cache: aiNodeRecsCache 24h." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4EDDA;strokeColor=#2C7A4B;strokeWidth=2;align=left;verticalAlign=top;fontSize=11;spacingLeft=12;spacingTop=8;fontColor=#1E5232" vertex="1" parent="1">
          <mxGeometry x="40" y="1310" width="900" height="160" as="geometry" />
        </mxCell>
        <mxCell id="tier_online" value="📰  Tier 2 — OpenAlex (NEW · external_lookup.py)&#10;Only when course tier weak AND _is_study_question(msg) AND topic extracted via _extract_topic.&#10;GET https://api.openalex.org/works?search={topic}&amp;filter=from_publication_date:{today-6y},type:journal-article|book|book-chapter|review-article|proceedings-article|report&amp;mailto={env OPENALEX_MAILTO}.&#10;Per-process LRU 1h.  verify_citation() enforces the 6-y window defensively." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4F0;strokeColor=#2C5282;strokeWidth=2;align=left;verticalAlign=top;fontSize=11;spacingLeft=12;spacingTop=8;fontColor=#1A365D" vertex="1" parent="1">
          <mxGeometry x="950" y="1310" width="910" height="160" as="geometry" />
        </mxCell>
        <mxCell id="tier_gk" value="🤖  Tier 3 — Gemini general knowledge&#10;Only when both above tiers are empty.&#10;Prompt now FORBIDS inline citations / [Source N] / Author(Year).&#10;Defensive re.sub strips any stragglers before the response is returned.&#10;Sources: [] (empty by design).  Banner tells the student to verify." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCEFD8;strokeColor=#9C6A1F;strokeWidth=2;align=left;verticalAlign=top;fontSize=11;spacingLeft=12;spacingTop=8;fontColor=#5C3E10" vertex="1" parent="1">
          <mxGeometry x="1870" y="1310" width="890" height="160" as="geometry" />
        </mxCell>
        <mxCell id="cta_box" value="💡  suggested_actions[] (chat response) → frontend CTA chips&#10;{ type: 'flashcards' | 'summary' | 'quiz', topic, evidence_tier, course_id? }&#10;Click → POST /ai/study-materials/generate-by-topic with the same evidence_tier.&#10;The new material is persisted to generatedStudyMaterials with evidenceTier, provenanceBanner, citations[].  The viewers render a tier-coloured banner at the top." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=11;spacingLeft=12;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="40" y="1490" width="2720" height="120" as="geometry" />
        </mxCell>
        <mxCell id="dash_strip" value="Style guard: chat prompt forbids em/en dashes (— –), and the handler runs response.replace('—', ', ').replace('–', '-') belt-and-braces.  Frontend renders buddy messages with react-markdown (web) / flutter_markdown (mobile)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=1;align=left;verticalAlign=top;fontSize=10;spacingLeft=12;spacingTop=6;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="1625" width="2720" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
