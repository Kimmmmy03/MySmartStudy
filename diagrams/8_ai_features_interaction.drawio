          <mxGeometry x="1220" y="120" width="270" height="210" as="geometry" />
        </mxCell>
        <mxCell id="r_grading" value="ai_grading&#10;&#10;/api/ai/grading/&#10;  recommend/{submission_id}&#10;  apply-recommendation&#10;&#10;Audience: Lecturer&#10;(tutorial-type only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
