<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="multiagent" name="Multi-Agent (Async vs CrewAI)">
    <mxGraphModel dx="2400" dy="1300" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="2800" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Multi-Agent — async fan-out for the chat (kept on both paths), CrewAI crew for grading (framework only, adaptive)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="2600" height="36" as="geometry" />
        </mxCell>

        <!-- TOP — AI COMPANION CHAT (same on both paths) -->
        <mxCell id="chat_panel" value="AI Companion chat  ·  routers/ai_companion.py  ·  same on legacy AND framework — async fan-out, no CrewAI here" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="2720" height="560" as="geometry" />
        </mxCell>

        <mxCell id="chat_in" value="POST /api/ai/companion/chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="120" y="130" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="intent" value="_looks_like_planning_request(msg)&#10;Free keyword classifier — no LLM call" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEDB3;strokeColor=#C99A06;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5C4400" vertex="1" parent="1">
          <mxGeometry x="460" y="115" width="320" height="80" as="geometry" />
        </mxCell>

        <mxCell id="delegate" value="Delegate to study-plan feature&#10;gag_service.generate_study_plan_artifact()&#10;Result formatted with _format_study_plan_for_chat()&#10;and streamed back word-by-word" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="850" y="100" width="430" height="110" as="geometry" />
        </mxCell>

        <mxCell id="fanout_box" value="Async fan-out (multi_agent.fan_out)  ·  asyncio.gather with 30s timeout and per-agent failure isolation (_safe_run)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6478;strokeWidth=1;align=center;verticalAlign=top;fontSize=12;fontStyle=1;fontColor=#3D4A5C;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="120" y="240" width="2560" height="180" as="geometry" />
        </mxCell>

        <mxCell id="ag_courses" value="_ctx_courses&#10;Firestore .where('enrolledStudents', 'array_contains', uid)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="160" y="290" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ag_deadlines" value="_ctx_deadlines&#10;Firestore — assignments, submissions, quizzes, attempts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="570" y="290" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ag_perf" value="_ctx_performance&#10;quizAttempts (limit 20) + graded submissions → weak_topics if &lt; 60%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="980" y="290" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ag_tt" value="_ctx_timetables&#10;savedTimetables.parsed_schedule + recommended_study_times" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1410" y="290" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ag_rem" value="_ctx_reminders&#10;reminders where isCompleted == False (limit 5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1840" y="290" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ag_ref" value="_ctx_reflections&#10;reflections order by createdAt desc (limit 3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="2250" y="290" width="400" height="100" as="geometry" />
        </mxCell>

        <mxCell id="synth" value="Synthesizer&#10;Build system prompt + RAG context + chat history → ai_service.chat_completion (SMART_MODEL).&#10;~1.5–2s end-to-end because all 6 lookups happened in parallel." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=12;spacingLeft=12;spacingTop=10;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="160" y="450" width="2490" height="100" as="geometry" />
        </mxCell>

        <mxCell id="chat_note" value="Why no CrewAI in the chat path&#10;The 6 'agents' here are Firestore lookups, not LLM reasoning.  Replacing them with CrewAI Agent calls would add N extra LLM round-trips and turn a ~2s chat reply into ~30s.  CrewAI is reserved for the grading flow below, where it actually adds reasoning value." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=11;fontColor=#3D4A5C;align=left;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="160" y="565" width="2490" height="60" as="geometry" />
        </mxCell>

        <!-- BOTTOM — AI GRADING (legacy vs framework, with complexity router) -->
        <mxCell id="grade_panel" value="AI Grading  ·  routers/ai_grading.py  ·  DIFFERS by AI_BACKEND" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F0F8;strokeColor=#6B46C1;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#4C2F87;spacingTop=8;align=left;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="40" y="680" width="2720" height="800" as="geometry" />
        </mxCell>

        <mxCell id="grade_in" value="POST /api/ai/grading/recommend/{submission_id}&#10;→ gag_service.generate_grading_report(submission, rubric, rag_chunks, assignment_info)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="120" y="730" width="2560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="grade_disp" value="framework_enabled() ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEDB3;strokeColor=#C99A06;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#5C4400" vertex="1" parent="1">
          <mxGeometry x="1250" y="810" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- legacy grading -->
        <mxCell id="L_grade" value="Legacy path&#10;generate_grading_report builds a JSON-by-example prompt and calls&#10;ai_service.generate_json — a SINGLE LLM call.  No multi-agent." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="120" y="930" width="1100" height="160" as="geometry" />
        </mxCell>

        <!-- framework grading with adaptive complexity router -->
        <mxCell id="F_grade_box" value="Framework path  ·  backend/app/crew_service.py" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6B46C1;strokeWidth=1;verticalAlign=top;align=left;spacingTop=6;spacingLeft=12;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1580" y="930" width="1100" height="430" as="geometry" />
        </mxCell>

        <mxCell id="F_complexity" value="_is_complex_submission()&#10;Free heuristic — no LLM call:&#10;words ≥ GRADING_CREW_MIN_WORDS (300)  OR  rubric ≥ GRADING_CREW_MIN_CRITERIA (3)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFEDB3;strokeColor=#C99A06;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#5C4400" vertex="1" parent="1">
          <mxGeometry x="1740" y="975" width="780" height="80" as="geometry" />
        </mxCell>

        <mxCell id="F_fast" value="false → fast path&#10;Single gag_service_lc.generate_grading_report() call:&#10;ChatGoogleGenerativeAI.with_structured_output(_GradingReport)&#10;~3s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1620" y="1080" width="500" height="140" as="geometry" />
        </mxCell>

        <mxCell id="F_crew" value="true → CrewAI crew&#10;_run_grading_crew():&#10;• Agent 1 — Submission Analyst (FAST_MODEL, max_iter=2)&#10;• Agent 2 — Grader (SMART_MODEL, max_iter=2)&#10;Process.sequential — Grader reads Analyst's output&#10;output_pydantic=_GradingReport → guaranteed schema" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="2150" y="1080" width="500" height="200" as="geometry" />
        </mxCell>

        <mxCell id="F_grade_note" value="Speed measures baked in:  the FAST path takes the easy submissions (most of them)&#10;and only the substantial work pays for the crew.  max_iter caps prevent agent loops." style="text;html=1;align=center;fontSize=10;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="1620" y="1290" width="1040" height="40" as="geometry" />
        </mxCell>

        <!-- ARROWS -->
        <mxCell id="a_chat" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="chat_in" target="intent"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_intent_yes" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#553C9A;strokeWidth=2;fontSize=11;fontColor=#3F2A6B" edge="1" parent="1" source="intent" target="delegate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_intent_no" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.05;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2;fontSize=11;fontColor=#3D4A5C" edge="1" parent="1" source="intent" target="fanout_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_fan_synth" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="fanout_box" target="synth"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="a_grade_disp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="grade_in" target="grade_disp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_disp_L" value="legacy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#2C5282;strokeWidth=2;fontSize=11;fontColor=#1F3A68" edge="1" parent="1" source="grade_disp" target="L_grade"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="670" y="850" /><mxPoint x="670" y="920" /></Array></mxGeometry></mxCell>
        <mxCell id="a_disp_F" value="framework" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2;fontSize=11;fontColor=#4C2F87" edge="1" parent="1" source="grade_disp" target="F_grade_box"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="2130" y="850" /><mxPoint x="2130" y="920" /></Array></mxGeometry></mxCell>
        <mxCell id="a_complex_fast" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2;fontSize=11;fontColor=#4C2F87" edge="1" parent="1" source="F_complexity" target="F_fast"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_complex_crew" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2;fontSize=11;fontColor=#4C2F87" edge="1" parent="1" source="F_complexity" target="F_crew"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
