<mxfile host="app.diagrams.net" agent="MySmartStudy" version="22.1.16">
  <diagram id="multiAgent" name="Multi-Agent Orchestration">
    <mxGraphModel dx="2400" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MySmartStudy — Multi-Agent Orchestration  (fan_out / fan_in over asyncio.gather)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="1600" height="36" as="geometry" />
        </mxCell>
        <mxCell id="sub" value="Source — backend/app/multi_agent.py.  Each &quot;agent&quot; is an async coroutine, dispatched in parallel.  Failures are isolated so other agents' results stay usable." style="text;html=1;align=center;whiteSpace=wrap;fontSize=12;fontStyle=2;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="200" y="60" width="2200" height="30" as="geometry" />
        </mxCell>

        <!-- ============ TOP ROW: callouts + boss + gate ============ -->
        <mxCell id="fail_box" value="Failure isolation — _safe_run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="380" height="32" as="geometry" />
        </mxCell>
        <mxCell id="fail_body" value="async def _safe_run(name, coro):&#10;  try:&#10;     return await coro&#10;  except Exception as e:&#10;     logger.warning('Agent %s failed: %s', name, e)&#10;     return {&quot;_error&quot;: str(e)}&#10;&#10;Result — one slow Firestore call or permission&#10;error never cancels the whole AI request.&#10;get_or_default(...) returns a fallback for that&#10;key. fan_out logs %d/%d agents succeeded&#10;in %.2fs." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6478;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=6;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="60" y="145" width="380" height="220" as="geometry" />
        </mxCell>

        <mxCell id="ingress" value="AI Router Endpoint&#10;(e.g. /api/ai/companion/chat)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1020" y="140" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gate" value="ai_service.set_tracking_context(uid, feature)&#10;→ master switch · per-feature kill list · quota" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DDE2EB;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="980" y="220" width="460" height="50" as="geometry" />
        </mxCell>

        <mxCell id="par_box" value="Speedup from parallelism" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E4A66;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="2120" y="110" width="380" height="32" as="geometry" />
        </mxCell>
        <mxCell id="par_body" value="Companion — 6 Firestore queries&#10;sequential ≈ 6 × ~180 ms = ~1.1 s&#10;parallel ≈ ~200 ms  (~5× faster)&#10;&#10;Grading — 3 reads (assignment +&#10;rubric + stats) collapse from&#10;~600 ms → ~210 ms.&#10;&#10;Both timeout at 30 s as a hard cap.&#10;Reports succeed even when one&#10;agent fails (graceful degrade).&#10;&#10;ai_companion._get_student_context()&#10;ai_grading.recommend_grade()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=6;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="2120" y="145" width="380" height="220" as="geometry" />
        </mxCell>

        <!-- ingress → gate (straight down) -->
        <mxCell id="ingress_arrow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="ingress" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ ORCHESTRATOR CORE (centered) ============ -->
        <mxCell id="core" value="Orchestrator — fan_out({name: coro}, timeout=30s)&#10;&#10;1) wrap each coro with _safe_run(name, coro):&#10;        try   →  await coro&#10;        except → return {&quot;_error&quot;: str(e)}   (warning logged)&#10;2) await asyncio.wait_for(asyncio.gather(*wrapped), timeout)&#10;3) zip back into { name: result } dict&#10;4) get_or_default(results, key, default)  ← returns default if &#39;_error&#39;&#10;&#10;Helper — fan_out_synthesize(agents, synthesizer):&#10;        results = await fan_out(...);   return await synthesizer(results)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=3;align=left;verticalAlign=top;fontSize=12;spacingLeft=14;spacingTop=10;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="800" y="320" width="820" height="280" as="geometry" />
        </mxCell>

        <!-- gate → core -->
        <mxCell id="gate_to_core" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#5A6478;strokeWidth=2" edge="1" parent="1" source="gate" target="core"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ EXAMPLE 1: COMPANION ============ -->
        <mxCell id="ex1_bg" value="Example 1 — AI Companion  (/api/ai/companion/chat)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="2520" height="380" as="geometry" />
        </mxCell>

        <mxCell id="ex1_lbl" value="fan_out({ courses, deadlines, performance, timetables, reminders, reflections })   →   6 agents in parallel" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#3D4A5C" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="2520" height="24" as="geometry" />
        </mxCell>

        <!-- 6 agents in row -->
        <mxCell id="a1" value="_ctx_courses(uid)&#10;&#10;Firestore — courses where&#10;array_contains uid&#10;&#10;→ {text, course_ids,&#10;     course_map}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="_ctx_deadlines(uid, now)&#10;&#10;Firestore — assignments,&#10;submissions, quizzes,&#10;attempts&#10;&#10;→ upcoming items [status]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="340" y="700" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="_ctx_performance(uid)&#10;&#10;quizAttempts (20)&#10;graded submissions&#10;&#10;→ scores, grades,&#10;   weak_topics (&lt; 60%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="600" y="700" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="_ctx_timetables(uid)&#10;&#10;savedTimetables&#10;parsed_schedule&#10;recommended_study_times&#10;&#10;→ formatted class blocks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="860" y="700" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="_ctx_reminders(uid)&#10;&#10;reminders where&#10;isCompleted == False&#10;limit 5&#10;&#10;→ task list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1120" y="700" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="a6" value="_ctx_reflections(uid)&#10;&#10;reflections orderBy&#10;createdAt desc limit 3&#10;&#10;→ avg confidence,&#10;    latest notes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCE7F3;strokeColor=#2C5282;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#1F3A68" vertex="1" parent="1">
          <mxGeometry x="1380" y="700" width="240" height="170" as="geometry" />
        </mxCell>

        <mxCell id="rag_step" value="rag_multistep.retrieve_multistep(query, course_ids, top_k=3)&#10;&#10;Sequential AFTER fan-out because it needs course_ids" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1660" y="700" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="synth1" value="Synthesizer — chat_completion()&#10;Gemini SMART_MODEL with merged context + RAG → grounded reply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="2080" y="700" width="420" height="80" as="geometry" />
        </mxCell>

        <!-- core → 6 agents via vertical bus at y=680 -->
        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.15;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="core" target="a1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="923" y="680" /><mxPoint x="200" y="680" /></Array></mxGeometry></mxCell>
        <mxCell id="ce2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.3;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="core" target="a2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1046" y="680" /><mxPoint x="460" y="680" /></Array></mxGeometry></mxCell>
        <mxCell id="ce3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.4;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="core" target="a3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1128" y="680" /><mxPoint x="720" y="680" /></Array></mxGeometry></mxCell>
        <mxCell id="ce4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="core" target="a4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1210" y="680" /><mxPoint x="980" y="680" /></Array></mxGeometry></mxCell>
        <mxCell id="ce5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.6;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="core" target="a5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1292" y="680" /><mxPoint x="1240" y="680" /></Array></mxGeometry></mxCell>
        <mxCell id="ce6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="core" target="a6"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1415" y="680" /><mxPoint x="1500" y="680" /></Array></mxGeometry></mxCell>

        <!-- a1 → rag_step (via right bus) , then rag → synth -->
        <mxCell id="conv1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="a6" target="rag_step"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="conv2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="rag_step" target="synth1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ EXAMPLE 2: GRADING ============ -->
        <mxCell id="ex2_bg" value="Example 2 — AI Grading  (/api/ai/grading/recommend/{submission_id})   TWO-WAVE fan-out" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;dashed=1;spacingTop=8;align=left;spacingLeft=18" vertex="1" parent="1">
          <mxGeometry x="40" y="1040" width="2520" height="420" as="geometry" />
        </mxCell>

        <mxCell id="ex2_pre" value="Pre-step — _fetch_submission(sid)&#10;needs to read submission first&#10;(to learn assignmentId)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="80" y="1090" width="290" height="100" as="geometry" />
        </mxCell>

        <mxCell id="ex2_w1" value="Wave 1 — fan_out({ assignment, class_stats })" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="420" y="1090" width="540" height="24" as="geometry" />
        </mxCell>
        <mxCell id="w1a1" value="_fetch_assignment_and_rubric(aid)&#10;&#10;assignments.{aid} +&#10;rubrics where assignmentId == aid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="420" y="1125" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="w1a2" value="_compute_class_stats(aid)&#10;&#10;mean / median / count from&#10;all graded submissions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0DAEF;strokeColor=#553C9A;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#3F2A6B" vertex="1" parent="1">
          <mxGeometry x="700" y="1125" width="260" height="110" as="geometry" />
        </mxCell>

        <mxCell id="ex2_w2" value="Wave 2 (sequential) — RAG retrieval needs courseId from wave 1" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1000" y="1090" width="540" height="24" as="geometry" />
        </mxCell>
        <mxCell id="w2a1" value="rag_service.retrieve(title + desc,&#10;[courseId], top_k=3)&#10;&#10;Returns top similar past materials" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#CFD8E3;strokeColor=#4A6E8C;align=left;verticalAlign=top;fontSize=10;spacingLeft=10;spacingTop=8;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="1000" y="1125" width="290" height="110" as="geometry" />
        </mxCell>

        <mxCell id="ex2_synth" value="Synthesizer&#10;gag_service.generate_grading_report(&#10;  submission_content, rubric,&#10;  rag_chunks, assignment_info{class_stats})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2D9F0;strokeColor=#6B46C1;strokeWidth=2;align=left;verticalAlign=top;fontSize=11;spacingLeft=10;spacingTop=8;fontStyle=1;fontColor=#4C2F87" vertex="1" parent="1">
          <mxGeometry x="1620" y="1115" width="380" height="130" as="geometry" />
        </mxCell>

        <mxCell id="ex2_persist" value="Persist to aiGradeRecommendations" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=14;fillColor=#CFD8E3;strokeColor=#4A6E8C;strokeWidth=2;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontColor=#2E4A66" vertex="1" parent="1">
          <mxGeometry x="2080" y="1145" width="380" height="80" as="geometry" />
        </mxCell>

        <!-- ex2 arrows -->
        <mxCell id="e2e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="ex2_pre" target="w1a1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=classic;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="ex2_pre" target="w1a2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="225" y="1260" /><mxPoint x="830" y="1260" /></Array></mxGeometry></mxCell>
        <mxCell id="e2e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="w1a1" target="w2a1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="980" y="1180" /></Array></mxGeometry></mxCell>
        <mxCell id="e2e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.7;endArrow=classic;dashed=1;strokeColor=#553C9A;strokeWidth=2" edge="1" parent="1" source="w1a2" target="ex2_synth"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1530" y="1180" /></Array></mxGeometry></mxCell>
        <mxCell id="e2e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;endArrow=classic;strokeColor=#6B46C1;strokeWidth=2" edge="1" parent="1" source="w2a1" target="ex2_synth"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;endArrow=classic;strokeColor=#4A6E8C;strokeWidth=2" edge="1" parent="1" source="ex2_synth" target="ex2_persist"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="ex2_note" value="Why two waves?&#10;&#10;The orchestrator can only parallelise tasks with no data dependency.&#10;RAG needs courseId, which lives inside the assignment record,&#10;so assignment must resolve first.  Class stats are independent,&#10;so they ride in the same wave as the assignment fetch —&#10;saving one round-trip." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#ECE9F3;strokeColor=#7A6B98;fontSize=10;fontColor=#3D4A5C;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="1300" width="2440" height="120" as="geometry" />
        </mxCell>

        <!-- ============ USERS LIST (between callouts at the top) ============ -->
        <mxCell id="users_box" value="Multi-agent users (live)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#5A6478;strokeWidth=2;align=center;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#3D4A5C;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="460" y="290" width="1500" height="32" as="geometry" />
        </mxCell>
        <mxCell id="users_body" value="• ai_companion.chat / chat-stream — 6 agents (courses, deadlines, performance, timetables, reminders, reflections)&#10;• ai_study_plan.daily_guide — 4 agents (courses, deadlines, performance, timetable) + RAG → GAG synthesizer&#10;• ai_grading.recommend — two-wave fan-out (assignment + stats || RAG) → GAG grading report&#10;• ai_plagiarism.analyze_assignment_network — fan-out (similarity || assignment validate) → cluster → GAG&#10;• ai_mindmap_buddy.suggest_all / recommend — fan-out for memory + map context + RAG → GAG graph suggestions" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#3D4A5C;spacingLeft=14" vertex="1" parent="1">
          <mxGeometry x="470" y="600" width="1480" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
